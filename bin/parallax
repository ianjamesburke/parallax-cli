def cmd_generate_still(args: argparse.Namespace) -> int:
    """
    Generate still images from a creative brief.

    Reads:  Optional --ref <image> files as visual reference.
    Writes: stills/<slug>.png per generated image.
    Exit:   0=success, 1=ffmpeg/API error, 2=invalid params.

    TEST_MODE: creates solid-color PNG stubs via ffmpeg — real files, no API calls.
    """
    import subprocess as _sp
    import hashlib

    brief = getattr(args, "brief", None)
    if not brief:
        print("[parallax] ERROR: generate still requires a brief", file=sys.stderr)
        return 2

    cwd = Path.cwd()
    sys.path.insert(0, str(REPO_ROOT))
    os.environ["PARALLAX_LOG_DIR"] = str(cwd / "logs")
    _ensure_project_layout(cwd)

    count = getattr(args, "count", 1) or 1
    stills_dir = cwd / "stills"
    stills_dir.mkdir(parents=True, exist_ok=True)

    test_mode = os.environ.get("TEST_MODE", "").lower() in ("1", "true", "yes")

    if test_mode:
        # Solid-color PNG stub via ffmpeg — real file, zero API spend.
        # Color is deterministic from brief so repeat runs produce the same output.
        color_hex = hashlib.md5(brief.encode()).hexdigest()[:6]
        timestamp = int(time.time())
        generated = []
        for i in range(1, count + 1):
            filename = f"still_{timestamp}_{i:02d}.png"
            still_path = stills_dir / filename
            try:
                _sp.run(
                    ["ffmpeg", "-f", "lavfi",
                     "-i", f"color=0x{color_hex}:s=1920x1080:d=1",
                     "-vframes", "1", "-y", str(still_path)],
                    capture_output=True, check=True, timeout=15,
                )
                generated.append(filename)
                print(f"[parallax] test-mode still {i}/{count} → stills/{filename}")
            except Exception as e:
                print(f"[parallax] ERROR: ffmpeg stub failed: {e}", file=sys.stderr)
                return 1

        # Write a V2-shaped manifest
        manifest_path = cwd / "manifest.yaml"
        project_name = cwd.name
        concept_id = f"TST-{timestamp % 1000:03d}"
        with open(manifest_path, "w") as f:
            f.write(f'project: "{project_name}"\n')
            f.write(f'concept_id: "{concept_id}"\n')
            f.write(f'brief: "{brief}"\n')
            f.write("scenes:\n")
            for idx, name in enumerate(generated, 1):
                f.write(f"  - number: {idx}\n")
                f.write(f'    title: "Scene {idx}"\n')
                f.write(f"    duration: 3.0\n")
                f.write(f'    still: "stills/{name}"\n')
                f.write(f'    motion: "zoom_drift_right"\n')

        print(f"[parallax] TEST_MODE: {len(generated)} still(s) → stills/")
        print(f"[parallax] manifest: ./manifest.yaml")
        return 0

    # Real mode: delegate to Gemini generation via cmd_create, adapting args shape.
    class _AdaptedArgs:
        def __init__(self):
            self.brief = args.brief
            self.count = getattr(args, "count", 1) or 1
            self.ref = getattr(args, "ref", None)
            self.style = getattr(args, "style", None)
            self.aspect_ratio = getattr(args, "aspect_ratio", "3:4") or "3:4"
            self.json = getattr(args, "json", False)
            self.stdin = False
    return cmd_create(_AdaptedArgs())


def cmd_generate_voice(args: argparse.Namespace) -> int:
    """
    Generate voiceover audio from a script or manifest VO lines.

    Reads:  Inline script text, or --from-manifest reads vo_text from manifest scenes.
    Writes: audio/<slug>.mp3
    Exit:   0=success, 1=API error, 2=manifest missing when --from-manifest is used.

    TEST_MODE: writes a silent WAV stub of approximate duration.
    """
    import subprocess as _sp

    cwd = Path.cwd()
    sys.path.insert(0, str(REPO_ROOT))
    os.environ["PARALLAX_LOG_DIR"] = str(cwd / "logs")
    _ensure_project_layout(cwd)

    from_manifest = getattr(args, "from_manifest", False)
    script_text = getattr(args, "script", None)
    test_mode = os.environ.get("TEST_MODE", "").lower() in ("1", "true", "yes")

    if from_manifest:
        manifest_path = cwd / "manifest.yaml"
        if not manifest_path.exists():
            print(f"[parallax] ERROR: manifest not found: {manifest_path}", file=sys.stderr)
            return 2
        try:
            import yaml as _yaml
            with open(manifest_path) as f:
                manifest = _yaml.safe_load(f) or {}
        except Exception as e:
            print(f"[parallax] ERROR: manifest parse failed: {e}", file=sys.stderr)
            return 2
        scenes = manifest.get("scenes") or []
        chunks = [(s.get("vo_text") or s.get("vo") or "").strip()
                  for s in scenes if isinstance(s, dict)]
        script_text = " ".join(c for c in chunks if c)

    if not script_text:
        print("[parallax] ERROR: generate voice requires script text or --from-manifest", file=sys.stderr)
        return 2

    audio_dir = cwd / "audio"
    audio_dir.mkdir(parents=True, exist_ok=True)

    engine = getattr(args, "engine", "elevenlabs")
    voice = getattr(args, "voice", None) or "Samantha"

    # Determine whether to use macOS `say`
    use_say = (
        engine == "say"
        or (test_mode and sys.platform == "darwin" and _sp.which("say"))
    )

    if use_say:
        if sys.platform != "darwin" or not _sp.which("say"):
            print(
                "[parallax] WARNING: --engine say requires macOS with `say` installed; "
                "falling back to silent stub.",
                file=sys.stderr,
            )
            use_say = False

    if use_say:
        import uuid as _uuid
        aiff_path = Path(f"/tmp/parallax-vo-{_uuid.uuid4().hex}.aiff")
        out_path = audio_dir / "voiceover.mp3"
        try:
            _sp.run(
                ["say", "-v", voice, "-o", str(aiff_path), script_text],
                capture_output=True, check=True, timeout=60,
            )
        except Exception as e:
            print(
                f"[parallax] WARNING: `say` failed ({e}); falling back to silent stub.",
                file=sys.stderr,
            )
            use_say = False
        if use_say:
            try:
                _sp.run(
                    ["ffmpeg", "-i", str(aiff_path), "-y", str(out_path)],
                    capture_output=True, check=True, timeout=30,
                )
                print(f"[parallax] say TTS → audio/voiceover.mp3 (voice: {voice})")
            except Exception as e:
                print(
                    f"[parallax] WARNING: ffmpeg AIFF→MP3 failed ({e}); falling back to silent stub.",
                    file=sys.stderr,
                )
                use_say = False
            finally:
                try:
                    aiff_path.unlink(missing_ok=True)
                except Exception:
                    pass
            if use_say:
                return 0

    # Fallback: silent stub for test_mode when say was unavailable or failed,
    # or when --engine say was requested but say/ffmpeg failed.
    # In real ElevenLabs mode (test_mode=False, engine="elevenlabs"), skip this block.
    needs_stub = test_mode or (engine == "say" and not use_say)
    if needs_stub:
        # Silent WAV stub — duration estimated at 150 WPM
        word_count = len(script_text.split())
        duration_s = max(1.0, word_count / 150.0 * 60.0)
        out_path = audio_dir / "voiceover.mp3"
        try:
            _sp.run(
                ["ffmpeg", "-f", "lavfi", "-i",
                 "anullsrc=r=44100:cl=mono",
                 "-t", str(duration_s), "-y", str(out_path)],
                capture_output=True, check=True, timeout=15,
            )
            print(f"[parallax] TEST_MODE: silent voice stub ({duration_s:.1f}s) → audio/voiceover.mp3")
        except Exception as e:
            print(f"[parallax] ERROR: ffmpeg audio stub failed: {e}", file=sys.stderr)
            return 1
        return 0

    # Real mode: delegate to cmd_voiceover with script override via stdin approach.
    # Build adapted args for cmd_voiceover.
    class _AdaptedArgs:
        def __init__(self):
            self.voice = getattr(args, "voice", None)
            self.model_id = None
            self.no_transcribe = True  # generate voice doesn't auto-transcribe
            self.json = getattr(args, "json", False)
            self.stdin = True  # pass script as JSON override

    import io
    adapted = _AdaptedArgs()
    old_stdin = sys.stdin
    sys.stdin = io.StringIO(json.dumps({"script": script_text}))
    try:
        rc = cmd_voiceover(adapted)
    finally:
        sys.stdin = old_stdin
    return rc


