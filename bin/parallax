def cmd_script_write(args: argparse.Namespace) -> int:
    """
    Write a video script from a brief using Claude.

    Reads:  Brief as inline argument.
    Writes: Script to stdout (or --out <file>).
    Exit:   0=success, 1=API error.

    TEST_MODE: outputs a deterministic placeholder script — no API calls.
    """
    import hashlib

    brief = getattr(args, "brief", None)
    if not brief:
        print("[parallax] ERROR: script write requires a brief", file=sys.stderr)
        return 2

    out_file = getattr(args, "out", None)
    test_mode = os.environ.get("TEST_MODE", "").lower() in ("1", "true", "yes")

    if test_mode:
        seed = hashlib.md5(brief.encode()).hexdigest()[:8]
        script = (
            f"[TEST MODE — deterministic script — seed: {seed}]\n\n"
            f"Brief: {brief}\n\n"
            "Scene 1 (0:00–0:08): Opening. Establish the world.\n"
            f"  VO: Welcome to a story about {brief[:50]}.\n\n"
            "Scene 2 (0:08–0:22): Core message. Make it land.\n"
            "  VO: Here is what you need to know. This is the heart of the story.\n\n"
            "Scene 3 (0:22–0:30): Close strong. Clear call to action.\n"
            "  VO: Ready to begin? Let's go.\n"
        )
        if out_file:
            Path(out_file).write_text(script)
            print(f"[parallax] script written to {out_file}")
        else:
            print(script)
        return 0

    # Real mode: call Claude to write the script.
    try:
        import anthropic
    except ImportError:
        print("[parallax] ERROR: anthropic package not installed. Run: pip install anthropic",
              file=sys.stderr)
        return 1

    api_key = os.environ.get("ANTHROPIC_API_KEY")
    if not api_key:
        print("[parallax] ERROR: ANTHROPIC_API_KEY not set", file=sys.stderr)
        return 1

    print("[parallax] writing script...", flush=True)
    try:
        client = anthropic.Anthropic(api_key=api_key)
        msg = client.messages.create(
            model="claude-sonnet-4-6",
            max_tokens=2048,
            messages=[{
                "role": "user",
                "content": (
                    "Write a tight video script for the following brief. "
                    "Format each scene as:\n"
                    "  Scene N (HH:MM–HH:MM): <visual description>\n"
                    "    VO: <voiceover line>\n\n"
                    "Keep the total under 60 seconds. Be specific and vivid.\n\n"
                    f"Brief: {brief}"
                )
            }]
        )
        script = msg.content[0].text
    except Exception as e:
        print(f"[parallax] ERROR: Claude API failed: {e}", file=sys.stderr)
        return 1

    if out_file:
        Path(out_file).write_text(script)
        print(f"[parallax] script written to {out_file}")
    else:
        print(script)
    return 0


def cmd_script_rewrite(args: argparse.Namespace) -> int:
    """
    Rewrite an existing script with a directive.

    Reads:  --from <file> (required) or stdin.
    Writes: Revised script to stdout (or --out <file>).
    Exit:   0=success, 1=API error, 2=source file not found.
    """
    from_file = getattr(args, "from_file", None)
    if from_file:
        p = Path(from_file)
        if not p.exists():
            print(f"[parallax] ERROR: source file not found: {from_file}", file=sys.stderr)
            return 2
        source = p.read_text()
    else:
        source = sys.stdin.read()

    instruction = getattr(args, "instruction", "") or ""
    out_file = getattr(args, "out", None)
    test_mode = os.environ.get("TEST_MODE", "").lower() in ("1", "true", "yes")

    if test_mode:
        revised = f"[TEST MODE rewrite — instruction: {instruction!r}]\n\n{source}"
        if out_file:
            Path(out_file).write_text(revised)
            print(f"[parallax] rewritten script → {out_file}")
        else:
            print(revised)
        return 0

    try:
        import anthropic
    except ImportError:
        print("[parallax] ERROR: anthropic package not installed. Run: pip install anthropic",
              file=sys.stderr)
        return 1

    api_key = os.environ.get("ANTHROPIC_API_KEY")
    if not api_key:
        print("[parallax] ERROR: ANTHROPIC_API_KEY not set", file=sys.stderr)
        return 1

    prompt = f"Rewrite the following video script. Instruction: {instruction}\n\nOriginal script:\n{source}"
    print("[parallax] rewriting script...", flush=True)
    try:
        client = anthropic.Anthropic(api_key=api_key)
        msg = client.messages.create(
            model="claude-sonnet-4-6",
            max_tokens=2048,
            messages=[{"role": "user", "content": prompt}]
        )
        revised = msg.content[0].text
    except Exception as e:
        print(f"[parallax] ERROR: Claude API failed: {e}", file=sys.stderr)
        return 1

    if out_file:
        Path(out_file).write_text(revised)
        print(f"[parallax] rewritten script → {out_file}")
    else:
        print(revised)
    return 0


def cmd_ingest(args: argparse.Namespace) -> int:
    """
    Analyze and index video files for use in a Parallax project.

    Reads:  <path|dir> — a video file or directory of video files.
    Writes: ingest/<clip-slug>/transcript.json and index.json per clip.
    Exit:   0=success, 1=file not found, 2=API error during transcription.

    --estimate: dry-run. Prints duration + cost projection, makes zero API calls.
    --visual:   adds Gemini Vision frame analysis (stub — not yet implemented).
    """
    import subprocess as _sp
    import hashlib

    path_arg = getattr(args, "path", None)
    estimate = getattr(args, "estimate", False)
    visual = getattr(args, "visual", False)
    test_mode = os.environ.get("TEST_MODE", "").lower() in ("1", "true", "yes")

    if not path_arg:
        print("[parallax] ERROR: ingest requires a path or directory", file=sys.stderr)
        return 1

    target = Path(path_arg).resolve()
    if not target.exists():
        print(f"[parallax] ERROR: not found: {target}", file=sys.stderr)
        return 1

    # Collect video files
    if target.is_dir():
        video_files = sorted(
            f for f in target.iterdir()
            if f.is_file() and f.suffix.lower() in VIDEO_EXTS
        )
    elif target.suffix.lower() in VIDEO_EXTS:
        video_files = [target]
    else:
        print(f"[parallax] ERROR: {target.name} is not a recognized video file", file=sys.stderr)
        return 1

    if not video_files:
        print(f"[parallax] ERROR: no video files found at {target}", file=sys.stderr)
        return 1

    # Probe durations via ffprobe
    total_duration = 0.0
    file_info = []
    for vf in video_files:
        try:
            probe = _sp.run(
                ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_format", str(vf)],
                capture_output=True, text=True, check=True, timeout=15,
            )
            dur = float(json.loads(probe.stdout)["format"]["duration"])
        except Exception:
            dur = 0.0
        total_duration += dur
        file_info.append({"path": vf, "duration": dur})
        print(f"[parallax] found: {vf.name} ({dur:.1f}s)")

    if estimate or test_mode:
        # Estimate only — no API calls
        whisper_cost = total_duration / 60.0 * 0.006  # $0.006/min
        gemini_cost = total_duration / 60.0 * 0.02 if visual else 0.0
        total_cost = whisper_cost + gemini_cost
        print()
        print(f"  files:             {len(file_info)}")
        print(f"  total duration:    {total_duration:.1f}s ({total_duration/60:.1f} min)")
        print(f"  transcription est: ${whisper_cost:.3f} (Whisper @ $0.006/min)")
        if visual:
            print(f"  visual analysis:   ${gemini_cost:.3f} (Gemini Vision @ $0.02/min)")
        print(f"  total estimated:   ${total_cost:.3f}")
        if estimate:
            return 0

    cwd = Path.cwd()
    sys.path.insert(0, str(REPO_ROOT))
    _ensure_project_layout(cwd)
    ingest_dir = cwd / "ingest"
    ingest_dir.mkdir(parents=True, exist_ok=True)

    if test_mode:
        # Write stub transcript + index for each file
        for info in file_info:
            vf = info["path"]
            slug = vf.stem.lower().replace(" ", "-")[:32]
            clip_dir = ingest_dir / slug
            clip_dir.mkdir(parents=True, exist_ok=True)
            file_hash = hashlib.md5(vf.name.encode()).hexdigest()[:16]

            transcript = {
                "file": vf.name,
                "duration_sec": round(info["duration"], 3),
                "language": "en",
                "segments": [
                    {"start": 0.0, "end": info["duration"],
                     "text": f"[TEST transcript for {vf.name}]"}
                ],
                "words": [],
                "test_mode": True,
            }
            index = {
                "file": vf.name,
                "slug": slug,
                "hash": file_hash,
                "duration_sec": round(info["duration"], 3),
                "frame_rate": 30.0,
                "resolution": "1920x1080",
                "language": "en",
                "test_mode": True,
            }
            (clip_dir / "transcript.json").write_text(json.dumps(transcript, indent=2))
            (clip_dir / "index.json").write_text(json.dumps(index, indent=2))
            print(f"[parallax] TEST_MODE: indexed {vf.name} → ingest/{slug}/")
        return 0

    # Real mode: transcription via WhisperX
    print("[parallax] transcription requires WhisperX — run `parallax transcribe` for single files")
    print("[parallax] bulk ingest transcription: coming in V2 final. Use --estimate for cost projection.")
    return 0


def cmd_web(args: argparse.Namespace) -> int:
    """
    Launch the Parallax web interface.

    Replaces `parallax chat`. Starts the parallax-web server and opens the
    local URL. Registers in ~/.parallax/servers.json on start.
    """
    return cmd_chat(args)


def cmd_project_list(args: argparse.Namespace) -> int:
    """List known parallax projects — same as `parallax projects`."""
    return cmd_projects(args)


def cmd_chat(args: argparse.Namespace) -> int:
    """
    Launch the localhost parallax-web chat UI in the default browser.

    Spawns `python3 -m parallax_web` with PYTHONPATH pointed at the web/
    directory bundled with this CLI. The subprocess handles its own port
    selection, HTTP server, SSE loop, and browser launch. Ctrl+C here is
    forwarded to the child for a clean shutdown.
    """
    import shutil as _shutil
    import subprocess as _subprocess

    web_dir = REPO_ROOT / "web"
    if not web_dir.is_dir():
        print(
            f"[parallax] ERROR: web/ directory not found at {web_dir}",
            file=sys.stderr,
        )
        return 2

    test_mode = bool(getattr(args, "test", False))

    if not test_mode and not os.environ.get("ANTHROPIC_API_KEY"):
        print(
            "[parallax chat] ANTHROPIC_API_KEY is not set. "
            "Export it and try again (or pass --test for mock mode):\n"
            "  export ANTHROPIC_API_KEY=sk-ant-...",
            file=sys.stderr,
        )
        return 2

    # Pick a python interpreter: prefer a web/.venv if present, otherwise
    # fall back to the current interpreter.
    venv_py = web_dir / ".venv" / "bin" / "python3"
    python_bin = str(venv_py) if venv_py.is_file() else (_shutil.which("python3") or sys.executable)

    if not test_mode:
        # Probe for the anthropic package; if missing, tell the user how to fix.
        probe = _subprocess.run(
            [python_bin, "-c", "import anthropic"],
            capture_output=True,
            text=True,
        )
        if probe.returncode != 0:
            print(
                "[parallax chat] the `anthropic` Python package isn't installed in\n"
                f"  {python_bin}\n"
                "Install it:\n"
                f"  cd \"{web_dir}\" && python3 -m venv .venv\n"
                f"  source .venv/bin/activate\n"
                "  pip install -r requirements.txt",
                file=sys.stderr,
            )
            return 2

    env = dict(os.environ)
    env["PYTHONPATH"] = str(web_dir) + (
        os.pathsep + env["PYTHONPATH"] if env.get("PYTHONPATH") else ""
    )
    env.setdefault("PARALLAX_PROJECT_DIR", os.getcwd())
    if test_mode:
        env["TEST_MODE"] = "true"
        print("[parallax chat] --test: mock mode (no paid API calls)", file=sys.stderr)

    try:
        proc = _subprocess.Popen(
            [python_bin, "-m", "parallax_web"],
            env=env,
            cwd=os.getcwd(),
        )
    except Exception as e:
        print(f"[parallax chat] failed to spawn server: {e}", file=sys.stderr)
        return 1

    try:
        return proc.wait()
    except KeyboardInterrupt:
        try:
            proc.terminate()
            proc.wait(timeout=5)
        except Exception:
            try:
                proc.kill()
            except Exception:
                pass
        return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="parallax", description="Parallax video pipeline CLI")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_run = sub.add_parser("run", help="kick off a footage_edit pipeline run in cwd")
    p_run.add_argument("brief", nargs="?", help="brief text for the footage edit (omit when using --stdin)")
    p_run.add_argument(
        "-y", "--yes",
        action="store_true",
        help="skip the clarification gate — assume the brief is fully specified and proceed with defaults",
    )
    p_run.add_argument("--json", action="store_true",
                       help="emit NDJSON events to stdout; human prose goes to stderr")
    p_run.add_argument("--stdin", action="store_true",
                       help="read a JSON job spec from stdin instead of using the positional brief")
    p_run.set_defaults(func=cmd_run)

    p_create = sub.add_parser("create", help="generate still images from a brief (no footage needed)")
    p_create.add_argument("brief", nargs="?", help="creative brief — what to generate (omit when using --stdin)")
    p_create.add_argument("--count", "-n", type=int, default=3, help="number of variations (default: 3)")
    p_create.add_argument("--ref", "-r", action="append", metavar="IMAGE", help="reference image path (can repeat)")
    p_create.add_argument("--style", "-s", metavar="IMAGE", help="style reference image path")
    p_create.add_argument("--aspect-ratio", "-a", default="3:4",
                          choices=["1:1","2:3","3:2","3:4","4:3","4:5","5:4","9:16","16:9"],
                          help="output aspect ratio (default: 3:4)")
    p_create.add_argument("--json", action="store_true",
                          help="emit NDJSON events to stdout; human prose goes to stderr")
    p_create.add_argument("--stdin", action="store_true",
                          help="read a JSON job spec from stdin instead of using the positional brief")
    p_create.set_defaults(func=cmd_create)

    p_animate = sub.add_parser("animate", help="Ken Burns animate stills → assembled draft video")
    p_animate.add_argument("--duration", "-d", type=float, default=4.0, help="seconds per still (default: 4)")
    p_animate.add_argument("--motion", "-m", default="zoom_drift_right",
                           choices=["zoom_in","zoom_out","zoom_drift_right","zoom_drift_left",
                                    "zoom_drift_down","zoom_drift_up","pan_right","pan_left","pan_down","pan_up"],
                           help="Ken Burns motion preset (default: zoom_drift_right)")
    p_animate.add_argument("--resolution", "-r", default="1080x1920", help="output resolution (default: 1080x1920)")
    p_animate.add_argument("--json", action="store_true",
                           help="emit NDJSON events to stdout; human prose goes to stderr")
    p_animate.set_defaults(func=cmd_animate)

    p_compose = sub.add_parser(
        "compose",
        help="render the project EXACTLY as specified in cwd/manifest.yaml — no globbing",
    )
    p_compose.add_argument("--json", action="store_true",
                           help="emit NDJSON events to stdout; human prose goes to stderr")
    p_compose.set_defaults(func=cmd_compose)

    p_voiceover = sub.add_parser(
        "voiceover",
        help="generate ElevenLabs voiceover and auto-transcribe with WhisperX",
    )
    p_voiceover.add_argument("--voice", default=None,
                             help="voice name shortcut (george/rachel/...) or raw voice_id")
    p_voiceover.add_argument("--model-id", dest="model_id", default=None,
                             help="ElevenLabs model id (default: eleven_v3)")
    p_voiceover.add_argument("--no-transcribe", dest="no_transcribe", action="store_true",
                             help="skip the auto WhisperX pass (you must run `parallax transcribe` later)")
    p_voiceover.add_argument("--json", action="store_true",
                             help="emit NDJSON events to stdout")
    p_voiceover.add_argument("--stdin", action="store_true",
                             help="read JSON job spec from stdin")
    p_voiceover.set_defaults(func=cmd_voiceover)

    p_transcribe = sub.add_parser(
        "transcribe",
        help="transcribe an audio file with WhisperX (the singular timing source). NO fallbacks.",
    )
    p_transcribe.add_argument("--audio", default=None,
                              help="audio file path (default: ./audio/voiceover.mp3)")
    p_transcribe.add_argument("--model", default="base.en",
                              help="whisperx model (default: base.en)")
    p_transcribe.add_argument("--language", default="en",
                              help="language code (default: en)")
    p_transcribe.add_argument("--json", action="store_true",
                              help="emit NDJSON events to stdout")
    p_transcribe.set_defaults(func=cmd_transcribe)

    p_trim = sub.add_parser(
        "trim-silence",
        help="remove silent gaps from audio/voiceover.mp3 and rewrite vo_manifest timestamps",
    )
    p_trim.add_argument("--json", action="store_true",
                        help="emit NDJSON events to stdout")
    p_trim.set_defaults(func=cmd_trim_silence)

    p_align = sub.add_parser(
        "align",
        help="align scene durations to voiceover word timestamps from vo_manifest.json",
    )
    p_align.add_argument("--json", action="store_true",
                         help="emit NDJSON events to stdout")
    p_align.set_defaults(func=cmd_align)

    p_manifest = sub.add_parser("manifest", help="edit or inspect cwd/manifest.yaml")
    p_manifest.add_argument(
        "op",
        choices=[
            "set-scenes", "add-scene", "add-video-scene", "remove-scene", "reorder",
            "set", "set-vo", "set-voice",
            "set-headline", "clear-headline",
            "enable-captions", "disable-captions",
            "show",
            "validate",   # V2: validate manifest against schema
        ],
        help="manifest operation",
    )
    p_manifest.add_argument("values", nargs="*", help="op-specific values")
    p_manifest.add_argument("--duration", type=float, default=3.0, help="duration for add-scene")
    p_manifest.add_argument("--start-s", dest="start_s", type=float, default=None,
                            help="start time in source video (add-video-scene)")
    p_manifest.add_argument("--end-s", dest="end_s", type=float, default=None,
                            help="end time in source video (add-video-scene)")
    p_manifest.add_argument(
        "--motion",
        choices=["zoom_in","zoom_out","zoom_drift_right","zoom_drift_left",
                 "zoom_drift_down","zoom_drift_up","pan_right","pan_left","pan_down","pan_up"],
        help="motion preset for add-scene",
    )
    p_manifest.set_defaults(func=cmd_manifest_edit)

    p_status = sub.add_parser("status", help="print manifest stats for the current project")
    p_status.set_defaults(func=cmd_status)

    # ── V2: generate ──────────────────────────────────────────────────────────
    p_generate = sub.add_parser("generate", help="generate stills, voice, or video")
    gen_sub = p_generate.add_subparsers(dest="generate_cmd", required=True)

    p_gen_still = gen_sub.add_parser("still", help="generate still images from a brief")
    p_gen_still.add_argument("brief", help="creative brief")
    p_gen_still.add_argument("--count", "-n", type=int, default=1,
                             help="number of images to generate (default: 1)")
    p_gen_still.add_argument("--ref", "-r", action="append", metavar="IMAGE",
                             help="reference image (can repeat)")
    p_gen_still.add_argument("--style", "-s", metavar="IMAGE", help="style reference image")
    p_gen_still.add_argument(
        "--aspect-ratio", "-a", default="3:4", dest="aspect_ratio",
        choices=["1:1", "2:3", "3:2", "3:4", "4:3", "4:5", "5:4", "9:16", "16:9"],
        help="output aspect ratio (default: 3:4)",
    )
    p_gen_still.add_argument("--json", action="store_true",
                             help="emit NDJSON events to stdout")
    p_gen_still.set_defaults(func=cmd_generate_still)

    p_gen_voice = gen_sub.add_parser("voice", help="generate voiceover audio from a script")
    p_gen_voice.add_argument("script", nargs="?", help="script text (inline or use --from-manifest)")
    p_gen_voice.add_argument("--from-manifest", dest="from_manifest", action="store_true",
                             help="read vo_text from manifest scenes instead of inline script")
    p_gen_voice.add_argument("--voice", default=None,
                             help="voice name or ElevenLabs voice ID (default for say: Samantha)")
    p_gen_voice.add_argument(
        "--engine",
        choices=["elevenlabs", "say"],
        default="elevenlabs",
        help=(
            "TTS engine to use. "
            "'elevenlabs' = cloud API (requires API key, see ELEVENLABS_API_KEY). "
            "'say' = macOS built-in TTS, free, no API key. Good for drafts. "
            "Run `say -v ?` for available voices."
        ),
    )
    p_gen_voice.add_argument("--json", action="store_true",
                             help="emit NDJSON events to stdout")
    p_gen_voice.set_defaults(func=cmd_generate_voice)

    p_gen_video = gen_sub.add_parser(
        "video",
        help="generate a video clip from a prompt [fal.ai — coming soon]",
    )
    p_gen_video.add_argument("prompt", help="video generation prompt")
    p_gen_video.add_argument("--ref", metavar="IMAGE", help="reference image for motion")
    p_gen_video.add_argument("--duration", type=int, default=5,
                             help="clip duration in seconds (default: 5)")
    p_gen_video.add_argument("--json", action="store_true")
    p_gen_video.set_defaults(func=cmd_generate_video)

    # ── V2: script ────────────────────────────────────────────────────────────
    p_script = sub.add_parser("script", help="write or rewrite video scripts")
    script_sub = p_script.add_subparsers(dest="script_cmd", required=True)

    p_script_write = script_sub.add_parser("write", help="write a video script from a brief")
    p_script_write.add_argument("brief", help="what the video is about")
    p_script_write.add_argument("--out", metavar="FILE",
                                help="write script to file instead of stdout")
    p_script_write.add_argument("--json", action="store_true")
    p_script_write.set_defaults(func=cmd_script_write)

    p_script_rewrite = script_sub.add_parser("rewrite", help="rewrite an existing script")
    p_script_rewrite.add_argument("--from", dest="from_file", metavar="FILE",
                                  help="source script file")
    p_script_rewrite.add_argument("--out", metavar="FILE",
                                  help="write result to file")
    p_script_rewrite.add_argument("--instruction", default="",
                                  help="rewrite directive (e.g. 'make it 30 seconds shorter')")
    p_script_rewrite.add_argument("--json", action="store_true")
    p_script_rewrite.set_defaults(func=cmd_script_rewrite)

    # ── V2: ingest ────────────────────────────────────────────────────────────
    p_ingest = sub.add_parser(
        "ingest",
        help="analyze and index video files — transcription + scene metadata",
    )
    p_ingest.add_argument("path", help="video file or directory of video files")
    p_ingest.add_argument("--visual", action="store_true",
                          help="add Gemini Vision frame analysis [coming soon]")
    p_ingest.add_argument("--estimate", action="store_true",
                          help="dry-run: print duration + cost estimate, no API calls")
    p_ingest.add_argument("--force", action="store_true",
                          help="re-ingest even if already indexed")
    p_ingest.add_argument("--json", action="store_true",
                          help="emit NDJSON progress events")
    p_ingest.set_defaults(func=cmd_ingest)

    # ── V2: web ───────────────────────────────────────────────────────────────
    p_web = sub.add_parser(
        "web",
        help="launch the Parallax web interface (replaces `parallax chat`)",
    )
    p_web.add_argument("--port", type=int, default=None, help="override default port")
    p_web.add_argument("--open", dest="open_browser", action="store_true",
                       help="open browser after startup")
    p_web.set_defaults(func=cmd_web)

    p_projects = sub.add_parser("projects", help="list known parallax projects")
    p_projects.set_defaults(func=cmd_projects)

    p_project = sub.add_parser("project", help="project management")
    proj_sub = p_project.add_subparsers(dest="project_cmd", required=True)
    p_new = proj_sub.add_parser("new", help="scaffold a new project directory")
    p_new.add_argument("name")
    p_new.set_defaults(func=cmd_project_new)
    p_proj_list = proj_sub.add_parser("list", help="list known parallax projects")
    p_proj_list.set_defaults(func=cmd_project_list)

    p_setup = sub.add_parser("setup", help="check dependencies and guide first-time setup")
    p_setup.set_defaults(func=cmd_setup)

    p_update = sub.add_parser("update", help="pull the latest Parallax from GitHub and re-install")
    p_update.set_defaults(func=cmd_update)

    p_publish = sub.add_parser("publish", help="publish finals to YouTube and social platforms [coming in v3]")
    p_publish.set_defaults(func=cmd_publish)

    p_chat = sub.add_parser(
        "chat",
        help="open the parallax-web localhost chat UI in the browser",
    )
    p_chat.add_argument(
        "--test",
        action="store_true",
        help="run the chat UI in TEST_MODE — mock LLM + image/video/voiceover calls, no API key required",
    )
    p_chat.set_defaults(func=cmd_chat)

    return parser


def main() -> int:
    import threading
    # Fire-and-forget daily update check — runs in background, zero latency impact
    t = threading.Thread(target=_check_for_update_once, daemon=True)
    t.start()

    parser = build_parser()
    args = parser.parse_args()
    rc = args.func(args)

    # Give the update check thread a moment to finish writing its cache/notice
    # before the process exits. 6s max — well within any command's runtime.
    t.join(timeout=6)
    return rc


if __name__ == "__main__":
    sys.exit(main())
