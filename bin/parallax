#!/usr/bin/env python3
"""
parallax — thin CLI wrapper for the Parallax video agent pipeline.

Commands:
    parallax run "brief text"     Kick off a footage_edit run in cwd.
    parallax status               Print manifest stats from the current project.
    parallax project new <name>   Scaffold ~/Documents/parallax-projects/<name>/.
    parallax projects             List known parallax projects.

Run-time layout:
    cwd/                    workspace root (in web beta:
                            <launch-dir>/parallax/users/<user>/<project>/)
    cwd/manifest.yaml       current project manifest
    cwd/stills/             generated images
    cwd/output/             final renders (latest deliverable per concept)
    cwd/drafts/             version history
    cwd/audio/              voiceovers + vo_manifest.json
    cwd/logs/               per-run log files (+ HoP per-concept subdirs)
"""

import argparse
import json as _json
import json  # alias for new code paths — avoids touching legacy _json refs
import logging
import os
import sys
import time
import uuid
from pathlib import Path

# Shared error-path helper. `fail(msg, where=..., exit_code=..., log=...)`
# emits a structured error event, logs with traceback, prints to stderr,
# and returns the exit code. Collapses every historical try/except ritual
# in this module into a one-line return.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from core.cli_errors import fail  # noqa: E402

PROJECTS_ROOT = Path.home() / "Documents" / "parallax-projects"
REPO_ROOT = Path(__file__).resolve().parent.parent
# Bundled video-production scripts — parallax is self-contained.
BUNDLED_SCRIPTS = REPO_ROOT / "packs" / "video" / "scripts"
VIDEO_EXTS = (".mp4", ".mov", ".m4v", ".mkv")


def _ensure_project_layout(cwd: Path) -> None:
    """Auto-scaffold the canonical Parallax project layout in cwd."""
    sys.path.insert(0, str(REPO_ROOT))
    from core.project_layout import ensure_project_layout
    ensure_project_layout(cwd)


def _find_clips(cwd: Path) -> list:
    """Glob video files in cwd/input (preferred), cwd, cwd/assets (legacy)."""
    out = []
    seen = set()
    for d in (cwd / "input", cwd, cwd / "assets"):
        if d.is_dir():
            for ext in VIDEO_EXTS:
                for p in sorted(d.glob(f"*{ext}")):
                    rp = p.resolve()
                    if rp not in seen:
                        seen.add(rp)
                        out.append(p)
    return [str(p) for p in out]


def _synthesize_test_clip(cwd: Path) -> str:
    """In TEST_MODE with no clips, create a 2s black clip so the pipeline has input."""
    import subprocess
    clip = cwd / "logs" / "_synthetic_clip.mp4"
    clip.parent.mkdir(parents=True, exist_ok=True)
    subprocess.run(
        ["ffmpeg", "-f", "lavfi", "-i", "color=black:s=320x240:d=2",
         "-f", "lavfi", "-i", "anullsrc=r=44100:cl=mono",
         "-t", "2", "-shortest", "-y", str(clip)],
        capture_output=True, check=True, timeout=30,
    )
    return str(clip)


def _resolve_brief(args: argparse.Namespace, required_fields: tuple = ("brief",)) -> dict:
    """
    Produce a job spec dict from either argv (brief positional + flags) or a
    JSON object on stdin when --stdin is set. Fails fast on missing/invalid input.
    """
    if getattr(args, "stdin", False):
        raw = sys.stdin.read()
        try:
            spec = _json.loads(raw)
        except _json.JSONDecodeError as e:
            print(f"[parallax] ERROR: --stdin expects a JSON object: {e}", file=sys.stderr)
            sys.exit(2)
        if not isinstance(spec, dict):
            print("[parallax] ERROR: --stdin JSON must be an object", file=sys.stderr)
            sys.exit(2)
        for f in required_fields:
            if not spec.get(f):
                print(f"[parallax] ERROR: --stdin JSON missing required field: {f!r}", file=sys.stderr)
                sys.exit(2)
        return spec
    # Build a spec from argv flags so downstream code only knows one shape.
    return {
        "brief": getattr(args, "brief", None),
        "count": getattr(args, "count", None),
        "style": getattr(args, "style", None),
        "ref": getattr(args, "ref", None),
        "aspect_ratio": getattr(args, "aspect_ratio", None),
    }


def cmd_run(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    # Repo root on sys.path FIRST so `from core...` works from any cwd.
    sys.path.insert(0, str(REPO_ROOT))

    # Resolve brief from argv or stdin JSON. Must happen before anything
    # that assumes args.brief is populated.
    spec = _resolve_brief(args)
    brief = spec["brief"]

    # Mint the run_id up front so the emitter, file logger, and HoP all share it.
    run_id = uuid.uuid4().hex[:8]

    # Enable NDJSON event emission BEFORE anything else that might print to
    # stdout (project layout init, clip scanning, etc.). enable_json() rebinds
    # sys.stdout → sys.stderr so existing prints don't corrupt the stream.
    from core.events import emitter
    if getattr(args, "json", False):
        emitter.enable_json(run_id)

    # Auto-scaffold canonical workspace layout (input/ output/ drafts/ stills/
    # audio/ logs/) and migrate loose media into input/ on first run. Idempotent.
    _ensure_project_layout(cwd)

    parallax_dir = cwd / "logs"
    parallax_dir.mkdir(parents=True, exist_ok=True)

    # Pin logs and HoP's internal project output under cwd/logs/. The
    # canonical *final* is republished to cwd/output/ at the end of the
    # pipeline via core/project_layout.py (see HoP footage_edit branch).
    os.environ["PARALLAX_LOG_DIR"] = str(parallax_dir)
    os.environ["PARALLAX_OUTPUT_ROOT"] = str(parallax_dir)

    # Install per-run file logging under logs/runs/<run_id>/parallax.log
    from core.logging_setup import setup_run_logging
    log_path = setup_run_logging(run_id)
    log = logging.getLogger("parallax.run")
    log.info("cmd_run start run_id=%s cwd=%s brief=%r", run_id, cwd, brief)

    test_mode = os.environ.get("TEST_MODE", "").strip().lower() in ("1", "true", "yes", "on")
    if test_mode:
        # Normalize so downstream agents (HoP, asset_generator) that check the
        # literal string "true" behave consistently regardless of how the user
        # spelled it on the command line.
        os.environ["TEST_MODE"] = "true"

    clips = _find_clips(cwd)
    if not clips:
        if test_mode:
            print("[parallax] TEST_MODE: no clips found — synthesizing a placeholder")
            log.info("TEST_MODE: synthesizing placeholder clip")
            clips = [_synthesize_test_clip(cwd)]
        else:
            print("           supported: " + ", ".join(VIDEO_EXTS), file=sys.stderr)
            return fail(
                "no video files found in cwd, ./assets, or ./input",
                where="cmd_run.find_clips", exit_code=2, log=log,
            )

    # Non-interactive: auto-confirm any prompts that slip past TEST_MODE.
    import builtins
    builtins.input = lambda _prompt="": ""

    from core.head_of_production import HeadOfProduction

    job = {
        "type": "footage_edit",
        "content": brief,  # HoP reads `content`, not `brief`
        "clips": clips,
        "run_id": run_id,
        "test_mode": test_mode,
        "skip_clarifications": bool(getattr(args, "yes", False)) or bool(getattr(args, "stdin", False)),
        # Project root for final-output routing: finals → cwd/output/,
        # drafts → cwd/drafts/. HoP reads this from the job dict.
        "project_root": str(cwd),
    }
    print(f"[parallax] brief: {brief!r}")
    print(f"[parallax] clips: {len(clips)} file(s)")
    print(f"[parallax] project dir: {parallax_dir}")
    if job["skip_clarifications"]:
        print("[parallax] --yes (or --stdin) set — skipping clarification gate")

    started_at = time.time()
    emitter.emit("run_started", brief=brief, mode="run", project_dir=str(parallax_dir))

    try:
        hop = HeadOfProduction(skip_health_check=True)
        # Force the HoP run_id to match ours so log paths and events line up.
        hop.run_id = run_id
        result = hop.receive_job(job)
    except Exception as e:
        return fail(f"pipeline failed: {e}", where="cmd_run.receive_job", log=log)

    status = result.get("status", "unknown")
    print(f"[parallax] status: {status}")
    concept = result.get("concept_id")
    if concept:
        print(f"[parallax] concept_id: {concept}")
        manifest = parallax_dir / concept / "manifest.yaml"
        if manifest.exists():
            print(f"[parallax] manifest: {manifest}")

    # Show the canonical final path relative to cwd if we have one.
    final_path = result.get("final_path")
    if final_path:
        try:
            rel = Path(final_path).resolve().relative_to(cwd.resolve())
            print(f"[parallax] final: ./{rel}")
        except ValueError:
            print(f"[parallax] final: {final_path}")
    copied = result.get("copied_to")
    if copied:
        print(f"[parallax] copied: {copied}")

    # Final spend print — uses the run-scoped cost tracker.
    try:
        from core.cost_tracker import get_run_cost
        from core.budget import BudgetGate
        run_id = result.get("run_id")
        spent = get_run_cost(run_id) if run_id else 0.0
        # Read the default total budget from BudgetGate (same default HoP uses).
        total_budget = 20.0
        try:
            if concept:
                bg = BudgetGate(concept)
                total_budget = bg.budget.total_budget
        except Exception:
            pass
        print(f"[HoP] Spent: ${spent:.3f} of ${total_budget:.2f} budget")
    except Exception as e:
        log.exception("could not read spend")
        print(f"[parallax] WARNING: could not read spend: {e}", file=sys.stderr)
        spent = 0.0

    duration_s = time.time() - started_at
    log.info("cmd_run complete status=%s duration_s=%.2f", status, duration_s)
    emitter.emit(
        "run_complete",
        output_path=final_path if final_path else None,
        status=status,
        cost_usd=round(spent, 4) if isinstance(spent, (int, float)) else None,
        duration_s=round(duration_s, 2),
    )

    return 0 if status == "complete" else 1


def cmd_status(args: argparse.Namespace) -> int:
    cwd = Path.cwd()
    # Prefer the flat workspace manifest (cmd_create / voiceover / compose).
    # Fall back to per-concept HoP manifests under logs/<concept>/manifest.yaml
    # for the legacy footage_edit (cmd_run) flow.
    flat = cwd / "manifest.yaml"
    parallax_dir = cwd / "logs"
    manifests: list[Path] = []
    if flat.exists():
        manifests.append(flat)
    if parallax_dir.exists():
        manifests.extend(
            sorted(parallax_dir.glob("*/manifest.yaml"),
                   key=lambda p: p.stat().st_mtime, reverse=True)
        )
    if not manifests:
        print("[parallax] no manifest.yaml in cwd or cwd/logs/<concept>/", file=sys.stderr)
        return 1

    manifest_path = manifests[0]
    try:
        import yaml
        with open(manifest_path) as f:
            data = yaml.safe_load(f) or {}
    except Exception as e:
        print(f"[parallax] ERROR: could not read {manifest_path}: {e}", file=sys.stderr)
        return 1

    footage = data.get("footage", {}) or {}
    source_clips = footage.get("source_clips", []) or []
    scenes = data.get("scenes", []) or footage.get("scenes", []) or []
    total_dur = 0.0
    for clip in source_clips:
        try:
            total_dur += max(0.0, float(clip.get("end_s", 0)) - float(clip.get("start_s", 0)))
        except Exception:
            pass

    stills_dir = manifest_path.parent / "stills"
    stills_count = len(list(stills_dir.glob("*.png"))) if stills_dir.exists() else 0

    print(f"manifest:    {manifest_path}")
    print(f"concept_id:  {manifest_path.parent.name}")
    print(f"scenes:      {len(scenes)}")
    print(f"clips:       {len(source_clips)}")
    print(f"duration:    {total_dur:.1f}s")
    print(f"stills:      {stills_count}")
    print(f"last run:    {data.get('run_id') or data.get('brief', {}).get('run_id') or 'unknown'}")
    return 0


def cmd_create(args: argparse.Namespace) -> int:
    """
    Generate still images from a brief — no footage required.

    Creates:
        cwd/stills/               generated images (PNG)
        cwd/manifest.yaml         project manifest (scenes + brief)
    """
    import random, string
    cwd = Path.cwd()
    sys.path.insert(0, str(REPO_ROOT))
    sys.path.insert(0, str(BUNDLED_SCRIPTS))

    # Resolve brief/options from argv or stdin JSON up front.
    spec = _resolve_brief(args)
    brief = spec["brief"]
    count = spec.get("count") or getattr(args, "count", 3) or 3
    style_ref = spec.get("style") or getattr(args, "style", None)
    ref_images = spec.get("ref") or getattr(args, "ref", None) or []
    aspect_ratio = spec.get("aspect_ratio") or getattr(args, "aspect_ratio", "3:4") or "3:4"

    run_id = uuid.uuid4().hex[:8]

    # Enable NDJSON mode BEFORE any pipeline code prints to stdout.
    from core.events import emitter
    if getattr(args, "json", False):
        emitter.enable_json(run_id)

    # Pin log dir to cwd/logs so logging_setup writes the per-run log file
    # under the current workspace.
    os.environ["PARALLAX_LOG_DIR"] = str(cwd / "logs")
    # Auto-scaffold the canonical layout in cwd (idempotent).
    _ensure_project_layout(cwd)

    from core.logging_setup import setup_run_logging
    log_path = setup_run_logging(run_id)
    log = logging.getLogger("parallax.create")
    log.info("cmd_create start run_id=%s brief=%r count=%s", run_id, brief, count)

    started_at = time.time()
    emitter.emit("run_started", brief=brief, mode="create", project_dir=str(cwd))

    _test_mode_active = os.environ.get("TEST_MODE", "").lower() == "true"

    # Structured request + cost events fire for BOTH the real and test
    # branches with identical shape — TEST MODE doubles as a dry-run cost
    # estimator, and the costs page folds these as projected spend.
    try:
        from core.instrumented import log_image_generation
        log_image_generation(
            model="gemini-3.1-flash-image-preview",
            count=count,
            brief=brief,
            aspect_ratio=aspect_ratio,
            ref_images=ref_images,
            test_mode=_test_mode_active,
        )
    except Exception as _e:
        log.warning("instrumented.log_image_generation failed: %s", _e)

    # TEST_MODE: short-circuit Gemini and produce placeholder stills locally.
    if _test_mode_active:
        stills_dir = cwd / "stills"
        stills_dir.mkdir(parents=True, exist_ok=True)
        (cwd / "logs").mkdir(parents=True, exist_ok=True)
        concept_id = "".join(random.choices(string.ascii_uppercase, k=3)) + "-" + str(random.randint(1, 999)).zfill(3)
        timestamp = int(time.time())
        generated_names = []
        try:
            from PIL import Image, ImageDraw
            have_pil = True
        except ImportError:
            have_pil = False
        for i in range(1, count + 1):
            filename = f"still_{timestamp}_{i:02d}.png"
            still_path = stills_dir / filename
            if have_pil:
                w, h = 1080, 1920
                shade = 50 + (i * 30) % 150
                img = Image.new("RGB", (w, h), color=(shade, shade, shade + 20))
                draw = ImageDraw.Draw(img)
                draw.rectangle([0, 0, w, 120], fill=(180, 40, 40))
                draw.text((30, 40), "TEST MODE — PLACEHOLDER", fill="white")
                draw.text((30, 150), f"Scene {i}", fill=(200, 200, 200))
                y = 220
                for chunk in [brief[j:j+44] for j in range(0, min(len(brief), 600), 44)]:
                    draw.text((30, y), chunk, fill=(220, 220, 220))
                    y += 36
                img.save(still_path)
            else:
                still_path.write_bytes(b"TEST_PLACEHOLDER")
            generated_names.append(filename)
            emitter.emit("still_generated", path=str(still_path), scene=i, prompt=brief)
            print(f"[parallax] test-mode still {i}/{count} -> stills/{filename}")

        manifest_path = cwd / "manifest.yaml"
        project_name = cwd.name
        with open(manifest_path, "w") as f:
            f.write(f'project: "{project_name}"\n')
            f.write(f'concept_id: "{concept_id}"\n')
            f.write(f'brief: "{brief}"\n')
            f.write("scenes:\n")
            for idx, name in enumerate(generated_names, 1):
                f.write(f"  - number: {idx}\n")
                f.write(f'    title: "Variation {idx}"\n')
                f.write(f"    duration: 3.0\n")
                f.write(f'    still: "stills/{name}"\n')

        duration_s = time.time() - started_at
        log.info("cmd_create TEST_MODE complete stills=%d duration_s=%.2f", len(generated_names), duration_s)
        emitter.emit(
            "run_complete",
            output_path=str(stills_dir),
            stills=len(generated_names),
            duration_s=round(duration_s, 2),
            test_mode=True,
        )
        print(f"[parallax] TEST_MODE: generated {len(generated_names)} placeholder still(s)")
        return 0

    try:
        from api_config import get_gemini_key
        from google import genai
        from google.genai import types as genai_types
    except ImportError as e:
        print("           install: pip install google-genai", file=sys.stderr)
        return fail(f"missing dependency: {e}", where="cmd_create.import",
                    exit_code=2, log=log)

    key = get_gemini_key()
    if not key:
        print("           set AI_VIDEO_GEMINI_KEY or GEMINI_API_KEY in your environment.", file=sys.stderr)
        print('           export AI_VIDEO_GEMINI_KEY="your-key-here"', file=sys.stderr)
        return fail("no Gemini API key found", where="cmd_create.no_key",
                    exit_code=2, log=log)

    # stills/ at the project root — this is where the Plexi viewer reads from
    stills_dir = cwd / "stills"
    stills_dir.mkdir(parents=True, exist_ok=True)
    (cwd / "logs").mkdir(parents=True, exist_ok=True)

    prompt_parts = [brief]
    if style_ref:
        prompt_parts.append(f"Style reference: {Path(style_ref).name}")
    # gemini-3.1-flash-image-preview reads aspect ratio from the prompt text.
    # The model's internal GenerateContentConfig has no aspect_ratio field, so
    # we bake the orientation hint into the prompt to force non-landscape outputs.
    if aspect_ratio:
        orient_hint = {
            "9:16": "Render in PORTRAIT orientation, 9:16 aspect ratio (tall/vertical, like a phone screen), NOT landscape.",
            "3:4":  "Render in PORTRAIT orientation, 3:4 aspect ratio (tall/vertical), NOT landscape.",
            "2:3":  "Render in PORTRAIT orientation, 2:3 aspect ratio (tall/vertical), NOT landscape.",
            "4:5":  "Render in PORTRAIT orientation, 4:5 aspect ratio (slightly tall), NOT landscape.",
            "1:1":  "Render as a SQUARE image, 1:1 aspect ratio.",
            "5:4":  "Render in LANDSCAPE orientation, 5:4 aspect ratio (slightly wide).",
            "4:3":  "Render in LANDSCAPE orientation, 4:3 aspect ratio.",
            "3:2":  "Render in LANDSCAPE orientation, 3:2 aspect ratio.",
            "16:9": "Render in LANDSCAPE orientation, 16:9 aspect ratio (wide cinematic).",
        }.get(aspect_ratio)
        if orient_hint:
            prompt_parts.append(orient_hint)
    prompt = ". ".join(prompt_parts)

    IMAGE_MODEL = "gemini-3.1-flash-image-preview"

    print(f"[parallax] brief:  {brief!r}")
    print(f"[parallax] count:  {count}")
    print(f"[parallax] model:  {IMAGE_MODEL}")
    if ref_images:
        print(f"[parallax] refs:   {', '.join(ref_images)}")
    print(f"[parallax] output: {stills_dir}")
    print()

    client = genai.Client(api_key=key)
    generated_names = []  # filenames only — manifest uses relative paths

    input_images = []
    for ref_path in ref_images:
        p = Path(ref_path)
        if not p.exists():
            print(f"[parallax] WARNING: ref image not found: {ref_path}", file=sys.stderr)
            continue
        suffix = p.suffix.lower().lstrip(".")
        mime = {"jpg": "image/jpeg", "jpeg": "image/jpeg", "png": "image/png", "webp": "image/webp"}.get(suffix, "image/png")
        input_images.append(genai_types.Part.from_bytes(data=p.read_bytes(), mime_type=mime))

    concept_id = "".join(random.choices(string.ascii_uppercase, k=3)) + "-" + str(random.randint(1, 999)).zfill(3)
    timestamp = int(time.time())

    # Variation hints — injected per-iteration when generating multiple images so
    # each request explores a meaningfully different direction rather than producing
    # near-identical outputs. Rotates through if count > len(hints).
    VARIATION_HINTS = [
        "Explore a distinct composition and lighting approach — make this variation clearly different from any others.",
        "Take an alternative angle on mood, color palette, and framing — contrast with other variations.",
        "Approach from a different perspective and atmosphere — bold or unexpected take on the concept.",
        "Lean into a graphic, high-contrast treatment — minimal yet striking.",
        "Softer, more cinematic interpretation — different tonal register from the others.",
    ]

    for i in range(1, count + 1):
        print(f"[parallax] generating {i}/{count}...", end=" ", flush=True)
        log.info("generating still %d/%d", i, count)
        try:
            # Always use Gemini 3.1 Flash Image Preview — handles both pure
            # text-to-image AND reference-image-conditioned generation.
            if count > 1:
                hint = VARIATION_HINTS[(i - 1) % len(VARIATION_HINTS)]
                iter_prompt = f"{prompt} {hint}"
            else:
                iter_prompt = prompt
            contents = list(input_images) + [genai_types.Part.from_text(text=iter_prompt)]
            response = client.models.generate_content(
                model=IMAGE_MODEL,
                contents=contents,
                config=genai_types.GenerateContentConfig(
                    response_modalities=["IMAGE", "TEXT"],
                ),
            )
            image_bytes = None
            for part in response.candidates[0].content.parts:
                if part.inline_data and part.inline_data.mime_type.startswith("image/"):
                    image_bytes = part.inline_data.data
                    break
            if not image_bytes:
                raise RuntimeError("no image in response")

            filename = f"still_{timestamp}_{i:02d}.png"
            still_path = stills_dir / filename
            still_path.write_bytes(image_bytes)
            generated_names.append(filename)
            log.info("still generated: %s", still_path)
            emitter.emit("still_generated", path=str(still_path), scene=i, prompt=prompt)
            print(f"done → stills/{filename}")
        except Exception as e:
            log.exception("still generation failed")
            emitter.emit("error", message=str(e), where=f"cmd_create.still_{i}")
            print(f"ERROR: {e}", file=sys.stderr)

    if not generated_names:
        return fail("no images generated", where="cmd_create.empty", log=log)

    # Manifest uses paths relative to cwd — portable across machines
    manifest_path = cwd / "manifest.yaml"
    project_name = cwd.name
    with open(manifest_path, "w") as f:
        f.write(f'project: "{project_name}"\n')
        f.write(f'concept_id: "{concept_id}"\n')
        f.write(f'brief: "{brief}"\n')
        f.write("scenes:\n")
        for idx, name in enumerate(generated_names, 1):
            f.write(f"  - number: {idx}\n")
            f.write(f'    title: "Variation {idx}"\n')
            f.write(f"    duration: 3.0\n")
            f.write(f'    still: "stills/{name}"\n')  # relative path

    print()
    print(f"[parallax] generated {len(generated_names)} still(s) → stills/")
    print(f"[parallax] manifest: ./manifest.yaml")
    print(f"[parallax] concept:  {concept_id}")
    print(f"[parallax] next:     parallax animate  (Ken Burns + assemble to output/)")

    duration_s = time.time() - started_at
    log.info("cmd_create complete stills=%d duration_s=%.2f", len(generated_names), duration_s)
    emitter.emit(
        "run_complete",
        output_path=str(stills_dir),
        stills=len(generated_names),
        duration_s=round(duration_s, 2),
    )
    return 0


def cmd_animate(args) -> int:
    """
    Convert stills/ images into Ken Burns video clips and assemble to output/.

    Reads:   cwd/stills/*.png  (or --stills path)
    Writes:  cwd/output/draft_<timestamp>.mp4
    Updates: cwd/manifest.yaml  (adds output_video field)
    """
    cwd = Path.cwd()
    # sys.path + auto-scaffold before anything else
    sys.path.insert(0, str(REPO_ROOT))
    os.environ["PARALLAX_LOG_DIR"] = str(cwd / "logs")
    _ensure_project_layout(cwd)

    run_id = uuid.uuid4().hex[:8]
    from core.events import emitter
    if getattr(args, "json", False):
        emitter.enable_json(run_id)
    from core.logging_setup import setup_run_logging
    setup_run_logging(run_id)
    log = logging.getLogger("parallax.animate")
    started_at = time.time()
    emitter.emit("run_started", brief="animate", mode="animate", project_dir=str(cwd))

    stills_dir = cwd / "stills"
    output_dir = cwd / "output"
    drafts_dir = cwd / "drafts"

    if not stills_dir.exists() or not list(stills_dir.glob("*.png")):
        print("[parallax] ERROR: no stills found in stills/", file=sys.stderr)
        print("           run `parallax create \"your brief\"` first", file=sys.stderr)
        return 1

    output_dir.mkdir(parents=True, exist_ok=True)
    drafts_dir.mkdir(parents=True, exist_ok=True)

    # ken-burns.py ships bundled inside parallax
    ken_burns_script = BUNDLED_SCRIPTS / "ken-burns.py"
    if not ken_burns_script.exists():
        print(f"[parallax] ERROR: ken-burns.py not found at {ken_burns_script}", file=sys.stderr)
        print(f"           (the parallax install looks corrupted — reinstall)", file=sys.stderr)
        return 1

    stills = sorted(stills_dir.glob("*.png"))
    duration = args.duration
    motion = args.motion
    resolution = args.resolution

    print(f"[parallax] animating {len(stills)} still(s) → Ken Burns clips")
    print(f"[parallax] motion:     {motion}  duration: {duration}s  resolution: {resolution}")
    print()

    import subprocess, tempfile
    clip_paths = []
    with tempfile.TemporaryDirectory(prefix="parallax-clips-") as tmpdir:
        for i, still in enumerate(stills, 1):
            clip_path = Path(tmpdir) / f"clip_{i:02d}.mp4"
            print(f"[parallax] animating {i}/{len(stills)}: {still.name}...", end=" ", flush=True)
            try:
                result = subprocess.run(
                    [sys.executable, str(ken_burns_script),
                     "--input", str(still),
                     "--output", str(clip_path),
                     "--duration", str(duration),
                     "--motion", motion,
                     "--resolution", resolution],
                    capture_output=True, text=True, timeout=120,
                )
                if result.returncode != 0:
                    print(f"FAILED\n{result.stderr.strip()}", file=sys.stderr)
                    continue
                clip_paths.append(str(clip_path))
                print("done")
            except Exception as e:
                print(f"ERROR: {e}", file=sys.stderr)

        if not clip_paths:
            print("[parallax] ERROR: no clips rendered", file=sys.stderr)
            return 1

        # Assemble clips with ffmpeg concat.
        # Name the final with the canonical <concept>_v<version>.mp4 convention.
        # Concept_id is read from the manifest if present; otherwise we mint a
        # timestamp-derived one so every animate run produces a versioned file.
        manifest_path = cwd / "manifest.yaml"
        concept_id = None
        if manifest_path.exists():
            try:
                import yaml as _yaml
                with open(manifest_path) as _f:
                    _m = _yaml.safe_load(_f) or {}
                concept_id = _m.get("concept_id")
            except Exception:
                concept_id = None
        if not concept_id:
            concept_id = f"ANM-{int(time.time()) % 1000:03d}"

        from core.project_layout import next_version, update_latest_symlink
        version = next_version(cwd, concept_id)
        output_path = output_dir / f"{concept_id}_v{version}.mp4"
        concat_list = Path(tmpdir) / "concat.txt"
        concat_list.write_text("\n".join(f"file '{p}'" for p in clip_paths))

        print(f"\n[parallax] assembling {len(clip_paths)} clips → {output_path.name}...", end=" ", flush=True)
        emitter.emit("assembly_started", clip_count=len(clip_paths), output_path=str(output_path))
        try:
            result = subprocess.run(
                ["ffmpeg", "-y", "-f", "concat", "-safe", "0",
                 "-i", str(concat_list),
                 "-c", "copy", str(output_path)],
                capture_output=True, text=True, timeout=300,
            )
            if result.returncode != 0:
                print(f"FAILED\n{result.stderr[-500:]}", file=sys.stderr)
                return fail(
                    f"ffmpeg concat failed rc={result.returncode}",
                    where="cmd_animate.assembly", log=log,
                )
            print("done")
            emitter.emit("assembly_complete", output_path=str(output_path))
        except Exception as e:
            return fail(f"assembly failed: {e}", where="cmd_animate.assembly", log=log)

    # Update manifest with output video path
    if manifest_path.exists():
        content = manifest_path.read_text()
        if "output_video:" in content:
            import re
            content = re.sub(r'output_video: ".*"', f'output_video: "output/{output_path.name}"', content)
        else:
            content += f'\noutput_video: "output/{output_path.name}"\n'
        manifest_path.write_text(content)

    # Point output/latest.mp4 at the new final.
    try:
        update_latest_symlink(cwd, output_path)
    except Exception as e:
        print(f"[parallax] WARNING: could not update latest.mp4: {e}", file=sys.stderr)

    print()
    print(f"[parallax] final: ./output/{output_path.name}")
    print(f"[parallax] the Plexi viewer will pick it up automatically")

    # Final spend print (best-effort — animate doesn't use HoP cost tracking,
    # so this will typically be $0.000 unless parallax create was run in the
    # same session with cost logging enabled).
    try:
        from core.cost_tracker import get_concept_cost
        spent = get_concept_cost(concept_id)
        print(f"[HoP] Spent: ${spent:.3f} of $20.00 budget")
    except Exception:
        pass

    duration_s = time.time() - started_at
    emitter.emit(
        "run_complete",
        output_path=str(output_path),
        duration_s=round(duration_s, 2),
    )
    return 0


VOICE_SHORTCUTS = {
    "george":  "JBFqnCBsd6RMkjVDRZzb",
    "rachel":  "21m00Tcm4TlvDq8ikWAM",
    "domi":    "AZnzlk1XvdvUeBnXmlld",
    "bella":   "EXAVITQu4vr4xnSDxMaL",
    "antoni":  "ErXwobaYiN019PkySvjV",
    "arnold":  "VR6AewLTigWG4xSOukaG",
}


def _whisperx_transcribe(audio_path: Path, language: str = "en", model: str = "base.en") -> tuple:
    """
    Run WhisperX phoneme-level forced alignment on an audio file.
    Returns (transcript_text, [{word, start, end}, ...]).

    THIS IS THE ONLY TRANSCRIPTION PATH IN PARALLAX. No fallbacks. No backends.
    If whisperx isn't installed, this raises ImportError and the caller fails fast.
    """
    import whisperx
    device = "cpu"
    print(f"[whisperx] loading model={model} device={device}...", flush=True)
    wx_model = whisperx.load_model(model, device, compute_type="int8", language=language)
    audio = whisperx.load_audio(str(audio_path))
    print(f"[whisperx] transcribing...", flush=True)
    result = wx_model.transcribe(audio, language=language)

    # Phoneme-level forced alignment for accurate word boundaries
    print(f"[whisperx] forced phoneme alignment...", flush=True)
    align_model, metadata = whisperx.load_align_model(language_code=language, device=device)
    result = whisperx.align(result["segments"], align_model, metadata, audio, device)

    transcript_parts = [s.get("text", "") for s in result.get("segments", [])]
    words = []
    for w in result.get("word_segments", []):
        word_text = w.get("word", "").strip()
        if not word_text:
            continue
        words.append({
            "word": word_text,
            "start": round(float(w.get("start", 0)), 3),
            "end": round(float(w.get("end", 0)), 3),
        })

    return " ".join(transcript_parts).strip(), words


def cmd_transcribe(args) -> int:
    """
    Transcribe an audio file with WhisperX (phoneme-level forced alignment).

    THE SINGULAR TRANSCRIPTION PATH. Every audio file that needs word-level
    timestamps in parallax MUST go through this command. No alternatives.

    Defaults to audio/voiceover.mp3 in the current project. Writes:
      audio/vo_manifest.json    — word-level timing from WhisperX

    Updates manifest.voiceover.transcribed = true.

    Exits 1 (fail loud) if whisperx is not installed — install it, do not fall back.
    """
    cwd = Path.cwd()
    sys.path.insert(0, str(REPO_ROOT))
    os.environ["PARALLAX_LOG_DIR"] = str(cwd / "logs")
    _ensure_project_layout(cwd)

    run_id = uuid.uuid4().hex[:8]
    from core.events import emitter
    if getattr(args, "json", False):
        emitter.enable_json(run_id)
    from core.logging_setup import setup_run_logging
    setup_run_logging(run_id)
    started_at = time.time()
    emitter.emit("run_started", brief="transcribe", mode="transcribe",
                 project_dir=str(cwd))

    # Resolve audio path: --audio flag or default
    audio_arg = getattr(args, "audio", None)
    if audio_arg:
        audio_path = Path(audio_arg).resolve()
    else:
        audio_path = cwd / "audio" / "voiceover.mp3"

    if not audio_path.exists():
        return fail(f"audio not found: {audio_path}",
                    where="cmd_transcribe.no_audio", exit_code=2)

    language = getattr(args, "language", "en") or "en"
    model = getattr(args, "model", "base.en") or "base.en"

    try:
        transcript, words = _whisperx_transcribe(audio_path, language=language, model=model)
    except ImportError as e:
        print("           parallax transcription REQUIRES whisperx — no fallback.", file=sys.stderr)
        print("           Install with: pip install whisperx", file=sys.stderr)
        return fail(f"whisperx is not installed: {e}",
                    where="cmd_transcribe.no_whisperx", exit_code=2)
    except Exception as e:
        return fail(f"whisperx failed: {e}", where="cmd_transcribe.whisperx_failed")

    # Probe duration
    import subprocess as _sp
    duration_s = 0.0
    try:
        probe = _sp.run(
            ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_format", str(audio_path)],
            capture_output=True, text=True, check=True,
        )
        duration_s = float(json.loads(probe.stdout)["format"]["duration"])
    except Exception as e:
        print(f"[parallax] WARNING: ffprobe failed: {e}", file=sys.stderr)

    print(f"[whisperx] transcribed {len(words)} words, {duration_s:.2f}s")

    # Write vo_manifest.json next to the audio file
    audio_dir = audio_path.parent
    audio_dir.mkdir(parents=True, exist_ok=True)
    vo_manifest_path = audio_dir / "vo_manifest.json"
    vo_manifest = {
        "audio_file": audio_path.name,
        "total_duration_s": round(duration_s, 3),
        "transcript": transcript,
        "transcribed_by": "whisperx",
        "model": model,
        "language": language,
        "words": words,
    }
    vo_manifest_path.write_text(json.dumps(vo_manifest, indent=2))
    print(f"[whisperx] wrote {vo_manifest_path}")

    # Update project manifest if present
    manifest_path = cwd / "manifest.yaml"
    if manifest_path.exists():
        try:
            import yaml as _yaml
            with open(manifest_path) as f:
                manifest = _yaml.safe_load(f) or {}
            vo = manifest.get("voiceover") or {}
            vo["vo_manifest"] = str(vo_manifest_path.relative_to(cwd))
            vo["duration_s"] = round(duration_s, 3)
            vo["transcribed"] = True
            vo["transcribed_by"] = "whisperx"
            manifest["voiceover"] = vo
            with open(manifest_path, "w") as f:
                _yaml.dump(manifest, f, sort_keys=False, default_flow_style=False)
        except Exception as e:
            print(f"[parallax] WARNING: manifest update failed: {e}", file=sys.stderr)

    duration_run = time.time() - started_at
    emitter.emit("run_complete",
                 audio_path=str(audio_path),
                 word_count=len(words),
                 duration_s=round(duration_run, 2))
    return 0


def _derive_word_timestamps(alignment, audio_duration: float) -> list:
    """Convert ElevenLabs character-level alignment to word-level timestamps."""
    chars = list(alignment.characters)
    starts = list(alignment.character_start_times_seconds)
    words = []
    current_word = ""
    word_start = None
    for i, char in enumerate(chars):
        if char.strip() == "":
            if current_word and word_start is not None:
                words.append({"word": current_word, "start": word_start})
                current_word = ""
                word_start = None
        else:
            if word_start is None:
                word_start = starts[i]
            current_word += char
    if current_word and word_start is not None:
        words.append({"word": current_word, "start": word_start})
    result = []
    for i, w in enumerate(words):
        end = words[i + 1]["start"] if i + 1 < len(words) else audio_duration
        result.append({
            "word": w["word"],
            "start": round(w["start"], 3),
            "end": round(end, 3),
        })
    return result


def cmd_voiceover(args) -> int:
    """
    Generate a voiceover MP3 + word-level timestamps from the manifest.

    Reads `vo_text` from each scene in cwd/manifest.yaml, concatenates,
    sends to ElevenLabs convert_with_timestamps. Writes:
      audio/voiceover.mp3
      audio/vo_manifest.json   — word-level timing for align + captions
    Updates manifest.voiceover with audio_file/duration/voice config.

    Voice config priority:
      1. CLI/--stdin override
      2. manifest.voice section
      3. default: george
    """
    cwd = Path.cwd()
    sys.path.insert(0, str(REPO_ROOT))
    sys.path.insert(0, str(BUNDLED_SCRIPTS))
    os.environ["PARALLAX_LOG_DIR"] = str(cwd / "logs")
    _ensure_project_layout(cwd)

    run_id = uuid.uuid4().hex[:8]
    from core.events import emitter
    if getattr(args, "json", False):
        emitter.enable_json(run_id)
    from core.logging_setup import setup_run_logging
    setup_run_logging(run_id)
    log = logging.getLogger("parallax.voiceover")
    started_at = time.time()
    emitter.emit("run_started", brief="voiceover", mode="voiceover",
                 project_dir=str(cwd))

    manifest_path = cwd / "manifest.yaml"
    if not manifest_path.exists():
        return fail(f"manifest not found: {manifest_path}",
                    where="cmd_voiceover.no_manifest", exit_code=2)

    import yaml as _yaml
    with open(manifest_path) as f:
        manifest = _yaml.safe_load(f) or {}

    # Read overrides from --stdin or CLI flags
    spec = {}
    if getattr(args, "stdin", False):
        raw = sys.stdin.read()
        try:
            spec = json.loads(raw)
        except Exception as e:
            return fail(f"--stdin expects JSON: {e}",
                        where="cmd_voiceover.stdin", exit_code=3)
    voice_input = spec.get("voice") or getattr(args, "voice", None)
    model_id = spec.get("model_id") or getattr(args, "model_id", None) or "eleven_v3"
    script_override = spec.get("script")

    # Build script text: explicit override > scene vo_text concatenation
    if script_override:
        script_text = script_override
    else:
        scenes = manifest.get("scenes") or []
        vo_chunks = []
        for s in scenes:
            t = (s.get("vo_text") or "").strip() if isinstance(s, dict) else ""
            if t:
                vo_chunks.append(t)
        script_text = " ".join(vo_chunks).strip()

    if not script_text:
        return fail(
            'no script text — set vo_text on each scene via '
            '`parallax manifest set-vo <scene> "<text>"` or pass '
            '{"script": "..."} via --stdin',
            where="cmd_voiceover.no_text", exit_code=3,
        )

    # Resolve voice — override > manifest.voice > george default
    if not voice_input:
        voice_cfg = manifest.get("voice") or {}
        voice_input = voice_cfg.get("voice_name") or voice_cfg.get("voice_id") or "george"
    voice_input = str(voice_input).strip()
    voice_id = VOICE_SHORTCUTS.get(voice_input.lower(), voice_input)
    voice_name = voice_input.title() if voice_input.lower() in VOICE_SHORTCUTS else voice_input

    _test_mode_vo = os.environ.get("TEST_MODE", "").lower() == "true"

    # Structured request + cost events fire for both real and test paths
    # so the costs page can fold projected voiceover spend.
    try:
        from core.instrumented import log_voiceover
        log_voiceover(
            model=model_id,
            voice_id=voice_id,
            voice_name=voice_name,
            script_text=script_text,
            test_mode=_test_mode_vo,
        )
    except Exception as _e:
        log.warning("instrumented.log_voiceover failed: %s", _e)

    # TEST_MODE: macOS `say` + ffmpeg for a real mp3, fake word timings so
    # cmd_align's prefix matching still works (words come from the actual script).
    if _test_mode_vo:
        import subprocess as _sp
        audio_dir = cwd / "audio"
        audio_dir.mkdir(parents=True, exist_ok=True)
        audio_path = audio_dir / "voiceover.mp3"
        vo_manifest_path_tm = audio_dir / "vo_manifest.json"
        aiff_path = audio_dir / "voiceover.aiff"

        print(f"[parallax] TEST_MODE: generating voiceover via macOS say...")
        try:
            _sp.run(["say", "-o", str(aiff_path), script_text],
                    check=True, capture_output=True, text=True, timeout=120)
        except Exception as e:
            return fail(f"macOS say failed: {e}",
                        where="cmd_voiceover.test_mode.say", log=log)
        try:
            _sp.run(["ffmpeg", "-y", "-hide_banner", "-loglevel", "error",
                     "-i", str(aiff_path),
                     "-codec:a", "libmp3lame", "-qscale:a", "2", str(audio_path)],
                    check=True, capture_output=True, text=True, timeout=120)
        except Exception as e:
            return fail(f"ffmpeg aiff->mp3 failed: {e}",
                        where="cmd_voiceover.test_mode.ffmpeg", log=log)
        try:
            aiff_path.unlink()
        except Exception:
            pass

        duration_s = 0.0
        try:
            probe = _sp.run(
                ["ffprobe", "-v", "quiet", "-print_format", "json",
                 "-show_format", str(audio_path)],
                capture_output=True, text=True, check=True,
            )
            duration_s = float(json.loads(probe.stdout)["format"]["duration"])
        except Exception:
            duration_s = max(1.0, len(script_text.split()) * 0.4)

        script_words = script_text.split()
        per_word = duration_s / max(len(script_words), 1)
        words_list = []
        for i, w in enumerate(script_words):
            start = round(i * per_word, 3)
            end = round((i + 1) * per_word, 3)
            words_list.append({"word": w, "start": start, "end": end})

        vo_manifest = {
            "audio_file": "voiceover.mp3",
            "total_duration_s": round(duration_s, 3),
            "transcript": script_text,
            "transcribed_by": "test_mode_stub",
            "model": "macos_say",
            "language": "en",
            "voice_id": voice_id,
            "voice_name": voice_name,
            "words": words_list,
        }
        vo_manifest_path_tm.write_text(json.dumps(vo_manifest, indent=2))

        manifest["voice"] = {
            "voice_id": voice_id,
            "voice_name": voice_name,
            "model_id": "test_mode",
        }
        manifest["voiceover"] = {
            "audio_file": "audio/voiceover.mp3",
            "vo_manifest": "audio/vo_manifest.json",
            "duration_s": round(duration_s, 3),
            "script": script_text,
            "transcribed": True,
            "transcribed_by": "test_mode_stub",
        }
        try:
            with open(manifest_path, "w") as f:
                _yaml.dump(manifest, f, sort_keys=False, default_flow_style=False)
        except Exception as e:
            print(f"[parallax] WARNING: manifest update failed: {e}", file=sys.stderr)

        print(f"[parallax] TEST_MODE voiceover: {duration_s:.2f}s, {len(words_list)} words")
        duration_run = time.time() - started_at
        emitter.emit("run_complete", output_path=str(audio_path),
                     duration_s=round(duration_run, 2),
                     audio_duration_s=round(duration_s, 2),
                     word_count=len(words_list),
                     test_mode=True)
        return 0

    try:
        from elevenlabs.client import ElevenLabs
        from elevenlabs.types import VoiceSettings
    except ImportError as e:
        return fail(f"elevenlabs not installed: {e}. Run: pip install elevenlabs",
                    where="cmd_voiceover.import", exit_code=2, log=log)
    try:
        from api_config import get_elevenlabs_key
    except ImportError as e:
        return fail(f"api_config import failed: {e}",
                    where="cmd_voiceover.api_config", exit_code=2, log=log)

    key = get_elevenlabs_key()
    if not key:
        return fail(
            "no ElevenLabs API key. Set ELEVENLABS_API_KEY or AI_VIDEO_ELEVENLABS_KEY.",
            where="cmd_voiceover.no_key", exit_code=2,
        )

    audio_dir = cwd / "audio"
    audio_dir.mkdir(parents=True, exist_ok=True)
    audio_path = audio_dir / "voiceover.mp3"
    vo_manifest_path = audio_dir / "vo_manifest.json"

    print(f"[parallax] script:  {len(script_text.split())} words")
    print(f"[parallax] voice:   {voice_name} ({voice_id})")
    print(f"[parallax] model:   {model_id}")
    print(f"[parallax] output:  {audio_path}")
    print()

    client = ElevenLabs(api_key=key)
    print(f"[parallax] calling ElevenLabs...", end=" ", flush=True)
    try:
        # Plain audio synthesis. We do NOT use convert_with_timestamps because
        # ElevenLabs's character-level alignment is less accurate than WhisperX
        # phoneme-level forced alignment. Word timings come from WhisperX below.
        audio_iter = client.text_to_speech.convert(
            text=script_text,
            voice_id=voice_id,
            model_id=model_id,
            output_format="mp3_44100_128",
            voice_settings=VoiceSettings(stability=0.5, similarity_boost=0.75),
        )
        audio_bytes = b"".join(audio_iter)
    except Exception as e:
        print("FAILED", file=sys.stderr)
        return fail(f"ElevenLabs call failed: {e}",
                    where="cmd_voiceover.api_call", log=log)

    audio_path.write_bytes(audio_bytes)
    print(f"done ({len(audio_bytes):,} bytes)")
    emitter.emit("voiceover_generated", path=str(audio_path), bytes=len(audio_bytes))

    # Persist voice config + voiceover stub to project manifest BEFORE transcription
    manifest["voice"] = {
        "voice_id": voice_id,
        "voice_name": voice_name,
        "model_id": model_id,
    }
    manifest["voiceover"] = {
        "audio_file": "audio/voiceover.mp3",
        "script": script_text,
    }
    try:
        with open(manifest_path, "w") as f:
            _yaml.dump(manifest, f, sort_keys=False, default_flow_style=False)
    except Exception as e:
        print(f"[parallax] WARNING: could not update manifest: {e}", file=sys.stderr)

    # ── WhisperX transcription (the singular timing path) ───────────────────
    # Auto-run unless --no-transcribe was passed. Word timings come from here.
    if not getattr(args, "no_transcribe", False):
        print()
        print(f"[parallax] running WhisperX transcription...")
        try:
            transcript, words = _whisperx_transcribe(audio_path)
        except ImportError as e:
            print("           install with: pip install whisperx", file=sys.stderr)
            print("           parallax has NO transcription fallback — whisperx is required.",
                  file=sys.stderr)
            return fail(f"whisperx not installed: {e}",
                        where="cmd_voiceover.transcribe", exit_code=2)
        except Exception as e:
            return fail(f"whisperx failed: {e}",
                        where="cmd_voiceover.transcribe", log=log)

        # Probe duration via ffprobe
        import subprocess as _sp
        duration_s = 0.0
        try:
            probe = _sp.run(
                ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_format", str(audio_path)],
                capture_output=True, text=True, check=True,
            )
            duration_s = float(json.loads(probe.stdout)["format"]["duration"])
        except Exception as e:
            print(f"[parallax] WARNING: ffprobe failed: {e}", file=sys.stderr)

        vo_manifest = {
            "audio_file": "voiceover.mp3",
            "total_duration_s": round(duration_s, 3),
            "transcript": transcript,
            "transcribed_by": "whisperx",
            "model": "base.en",
            "language": "en",
            "voice_id": voice_id,
            "voice_name": voice_name,
            "words": words,
        }
        vo_manifest_path.write_text(json.dumps(vo_manifest, indent=2))
        print(f"[whisperx] wrote {vo_manifest_path}")
        print(f"[whisperx] transcribed {len(words)} words, {duration_s:.2f}s")

        # Update manifest with full vo info
        manifest["voiceover"] = {
            "audio_file": "audio/voiceover.mp3",
            "vo_manifest": "audio/vo_manifest.json",
            "duration_s": round(duration_s, 3),
            "script": script_text,
            "transcribed": True,
            "transcribed_by": "whisperx",
        }
        try:
            with open(manifest_path, "w") as f:
                _yaml.dump(manifest, f, sort_keys=False, default_flow_style=False)
        except Exception as e:
            print(f"[parallax] WARNING: manifest update failed: {e}", file=sys.stderr)
    else:
        words = []
        duration_s = 0.0
        print(f"[parallax] skipped transcription (--no-transcribe)")
        print(f"[parallax] you must run `parallax transcribe` before `parallax align`")

    print()
    print(f"[parallax] voiceover: ./audio/voiceover.mp3 ({duration_s:.2f}s)")
    print(f"[parallax] next:      parallax align  (sync scene durations to whisperx timings)")

    duration_run = time.time() - started_at
    emitter.emit("run_complete", output_path=str(audio_path),
                 duration_s=round(duration_run, 2),
                 audio_duration_s=round(duration_s, 2),
                 word_count=len(words))
    return 0


def cmd_trim_silence(args) -> int:
    """
    Detect and trim silent gaps in audio/voiceover.mp3, then rewrite the
    word-level timestamps in audio/vo_manifest.json to match the new audio.

    Strategy:
      1. ffmpeg silencedetect → list of silent regions
      2. Build keep segments (everything except silences > min_silence)
      3. Concat keep segments → new audio in place of old
      4. For each word in vo_manifest, project its old timestamp through the
         segment map to get its new timestamp.
    """
    cwd = Path.cwd()
    sys.path.insert(0, str(REPO_ROOT))
    os.environ["PARALLAX_LOG_DIR"] = str(cwd / "logs")
    _ensure_project_layout(cwd)

    run_id = uuid.uuid4().hex[:8]
    from core.events import emitter
    if getattr(args, "json", False):
        emitter.enable_json(run_id)
    from core.logging_setup import setup_run_logging
    setup_run_logging(run_id)
    started_at = time.time()
    emitter.emit("run_started", brief="trim-silence", mode="trim_silence",
                 project_dir=str(cwd))

    audio_path = cwd / "audio" / "voiceover.mp3"
    vo_manifest_path = cwd / "audio" / "vo_manifest.json"
    if not audio_path.exists():
        return fail(
            f"voiceover not found at {audio_path} — run `parallax voiceover` first",
            where="cmd_trim_silence.missing_audio", exit_code=2,
        )

    import subprocess as _sp
    import re as _re

    MIN_SILENCE = 0.5  # seconds — only trim gaps longer than this
    PAD = 0.15         # seconds — preserve this much on each side of a cut
    THRESHOLD_DB = -35

    # Probe original duration
    try:
        probe = _sp.run(
            ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_format", str(audio_path)],
            capture_output=True, text=True, check=True,
        )
        original_dur = float(json.loads(probe.stdout)["format"]["duration"])
    except Exception as e:
        return fail(f"ffprobe failed: {e}",
                    where="cmd_trim_silence.ffprobe")

    print(f"[parallax] detecting silences (>{MIN_SILENCE}s, <{THRESHOLD_DB}dB)...", end=" ", flush=True)
    detect = _sp.run(
        ["ffmpeg", "-hide_banner", "-i", str(audio_path),
         "-af", f"silencedetect=noise={THRESHOLD_DB}dB:d={MIN_SILENCE}",
         "-f", "null", "-"],
        capture_output=True, text=True,
    )
    starts = [float(x) for x in _re.findall(r'silence_start: ([\d.]+)', detect.stderr)]
    ends = [float(x) for x in _re.findall(r'silence_end: ([\d.]+)', detect.stderr)]
    silences = []
    for s, e in zip(starts, ends):
        # Clamp to padded region
        cs = s + PAD
        ce = e - PAD
        if ce > cs:
            silences.append((cs, ce))
    print(f"found {len(silences)}")

    if not silences:
        print("[parallax] nothing to trim")
        duration_run = time.time() - started_at
        emitter.emit("run_complete", output_path=str(audio_path),
                     duration_s=round(duration_run, 2), trimmed=0)
        return 0

    # Build keep segments (inverse of silence regions)
    keeps = []
    cursor = 0.0
    for cs, ce in silences:
        if cs > cursor:
            keeps.append((cursor, cs))
        cursor = ce
    if cursor < original_dur:
        keeps.append((cursor, original_dur))

    print(f"[parallax] keeping {len(keeps)} segment(s)")

    # ffmpeg concat via filter: select multiple atrims and concat them.
    import tempfile
    with tempfile.TemporaryDirectory(prefix="parallax-trim-") as tmpdir:
        out_path = Path(tmpdir) / "trimmed.mp3"
        # Build a single -filter_complex with N atrims and a concat
        filter_parts = []
        for i, (s, e) in enumerate(keeps):
            filter_parts.append(f"[0:a]atrim={s}:{e},asetpts=PTS-STARTPTS[a{i}]")
        concat_inputs = "".join(f"[a{i}]" for i in range(len(keeps)))
        filter_parts.append(f"{concat_inputs}concat=n={len(keeps)}:v=0:a=1[out]")
        filter_complex = ";".join(filter_parts)

        result = _sp.run(
            ["ffmpeg", "-y", "-hide_banner", "-loglevel", "warning",
             "-i", str(audio_path),
             "-filter_complex", filter_complex,
             "-map", "[out]",
             "-c:a", "libmp3lame", "-b:a", "128k",
             str(out_path)],
            capture_output=True, text=True,
        )
        if result.returncode != 0 or not out_path.exists():
            msg = (result.stderr or "ffmpeg trim failed").strip()[-500:]
            return fail(msg, where="cmd_trim_silence.ffmpeg")

        # Replace the original
        out_path.replace(audio_path)

    # Reprobe new duration
    probe2 = _sp.run(
        ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_format", str(audio_path)],
        capture_output=True, text=True, check=True,
    )
    new_dur = float(json.loads(probe2.stdout)["format"]["duration"])
    removed = original_dur - new_dur
    print(f"[parallax] trimmed: {original_dur:.2f}s → {new_dur:.2f}s (removed {removed:.2f}s)")

    # Project word timestamps through the keep map
    if vo_manifest_path.exists():
        try:
            with open(vo_manifest_path) as f:
                vo_data = json.load(f)
            old_words = vo_data.get("words") or []
            # Build cumulative offsets: for each old time t, new time = sum of
            # keep_lengths before t + (t - keep_start) if t falls inside a keep
            new_words = []
            for w in old_words:
                old_t = w["start"]
                new_t = None
                offset = 0.0
                for ks, ke in keeps:
                    if old_t >= ks and old_t <= ke:
                        new_t = offset + (old_t - ks)
                        break
                    offset += (ke - ks)
                if new_t is None:
                    # Word was inside a removed silence — drop it
                    continue
                old_e = w["end"]
                new_e = None
                offset_e = 0.0
                for ks, ke in keeps:
                    if old_e >= ks and old_e <= ke:
                        new_e = offset_e + (old_e - ks)
                        break
                    offset_e += (ke - ks)
                if new_e is None:
                    new_e = new_t + 0.1
                new_words.append({
                    "word": w["word"],
                    "start": round(new_t, 3),
                    "end": round(new_e, 3),
                })
            vo_data["words"] = new_words
            vo_data["total_duration_s"] = round(new_dur, 3)
            vo_data["trimmed"] = True
            vo_manifest_path.write_text(json.dumps(vo_data, indent=2))
            print(f"[parallax] vo_manifest: {len(new_words)} words rewritten")
        except Exception as e:
            print(f"[parallax] WARNING: vo_manifest rewrite failed: {e}", file=sys.stderr)

    # Update project manifest with new duration
    manifest_path = cwd / "manifest.yaml"
    if manifest_path.exists():
        try:
            import yaml as _yaml
            with open(manifest_path) as f:
                manifest = _yaml.safe_load(f) or {}
            vo = manifest.get("voiceover") or {}
            vo["duration_s"] = round(new_dur, 3)
            vo["trimmed"] = True
            manifest["voiceover"] = vo
            with open(manifest_path, "w") as f:
                _yaml.dump(manifest, f, sort_keys=False, default_flow_style=False)
        except Exception as e:
            print(f"[parallax] WARNING: project manifest rewrite failed: {e}", file=sys.stderr)

    duration_run = time.time() - started_at
    emitter.emit("run_complete", output_path=str(audio_path),
                 duration_s=round(duration_run, 2),
                 removed_s=round(removed, 2))
    return 0


def cmd_align(args) -> int:
    """
    Align scene durations to voiceover word timestamps.

    For each scene with `vo_text`, find the start of its first word in
    audio/vo_manifest.json and the start of the next scene's first word.
    The difference is the new scene duration. Last scene runs to end of audio.

    Scenes without vo_text keep their existing duration.
    """
    cwd = Path.cwd()
    sys.path.insert(0, str(REPO_ROOT))
    os.environ["PARALLAX_LOG_DIR"] = str(cwd / "logs")
    _ensure_project_layout(cwd)

    run_id = uuid.uuid4().hex[:8]
    from core.events import emitter
    if getattr(args, "json", False):
        emitter.enable_json(run_id)
    from core.logging_setup import setup_run_logging
    setup_run_logging(run_id)
    started_at = time.time()
    emitter.emit("run_started", brief="align", mode="align",
                 project_dir=str(cwd))

    manifest_path = cwd / "manifest.yaml"
    vo_manifest_path = cwd / "audio" / "vo_manifest.json"
    if not manifest_path.exists():
        return fail(f"manifest not found: {manifest_path}",
                    where="cmd_align.no_manifest", exit_code=2)
    if not vo_manifest_path.exists():
        return fail(
            f"vo_manifest not found at {vo_manifest_path} — run `parallax voiceover` first",
            where="cmd_align.no_vo_manifest", exit_code=2,
        )

    import yaml as _yaml
    with open(manifest_path) as f:
        manifest = _yaml.safe_load(f) or {}
    with open(vo_manifest_path) as f:
        vo_data = json.load(f)

    words = vo_data.get("words") or []
    audio_duration = vo_data.get("total_duration_s") or 0.0
    if not words:
        print("[parallax] WARNING: no word timestamps in vo_manifest", file=sys.stderr)
        return 1

    scenes = manifest.get("scenes") or []
    if not scenes:
        print("[parallax] ERROR: manifest has no scenes", file=sys.stderr)
        return 1

    # For each scene with vo_text, find the start time of its first word
    # in the global word timeline. We use a multi-word prefix match (up to 3
    # consecutive words) so common short words like "In", "The", "And" don't
    # false-positive on earlier occurrences in another sentence.
    def _norm(w: str) -> str:
        return w.lower().strip(".,!?;:\"'()[]")

    word_idx = 0
    scene_starts = []  # parallel to scenes; None means no vo_text
    for scene in scenes:
        vo_text = (scene.get("vo_text") or "").strip() if isinstance(scene, dict) else ""
        if not vo_text:
            scene_starts.append(None)
            continue
        scene_words = [_norm(w) for w in vo_text.split() if _norm(w)]
        if not scene_words:
            scene_starts.append(None)
            continue

        # Try a 3-word prefix match first, fall back to 2-word, then 1-word.
        # Always walking forward from word_idx so scenes match in order.
        found = None
        found_at = None
        for prefix_len in (3, 2, 1):
            if prefix_len > len(scene_words):
                continue
            target = scene_words[:prefix_len]
            for j in range(word_idx, len(words) - prefix_len + 1):
                window = [_norm(words[j + k]["word"]) for k in range(prefix_len)]
                if window == target:
                    found = words[j]["start"]
                    found_at = j
                    break
            if found is not None:
                break

        if found is None:
            print(f"[parallax] WARNING: scene {scene.get('number','?')} prefix "
                  f"{scene_words[:3]!r} not found in voiceover", file=sys.stderr)
            scene_starts.append(None)
        else:
            scene_starts.append(found)
            word_idx = found_at + 1

    # Snap the first vo'd scene to t=0 so any lead-in silence is covered.
    # Without this, scene 1 starts at its first word's start time and there's
    # uncovered audio at the head, which -shortest clips at the tail.
    first_vo_idx = next((i for i, s in enumerate(scene_starts) if s is not None), None)
    if first_vo_idx is not None:
        scene_starts[first_vo_idx] = 0.0

    # Compute durations: each scene runs from its start to the next scene's start
    # (or to end of audio for the last vo'd scene).
    aligned_count = 0
    for i, scene in enumerate(scenes):
        if scene_starts[i] is None:
            continue
        # Find the next scene that has a start time
        next_start = None
        for j in range(i + 1, len(scenes)):
            if scene_starts[j] is not None:
                next_start = scene_starts[j]
                break
        if next_start is None:
            next_start = audio_duration
        new_dur = round(next_start - scene_starts[i], 3)
        if new_dur > 0.1:
            scene["duration"] = new_dur
            aligned_count += 1
            print(f"[parallax] scene {scene.get('number','?')}: {new_dur:.2f}s "
                  f"({scene_starts[i]:.2f}–{next_start:.2f})")

    with open(manifest_path, "w") as f:
        _yaml.dump(manifest, f, sort_keys=False, default_flow_style=False)

    print()
    print(f"[parallax] aligned {aligned_count} scene(s) to voiceover timing")
    print(f"[parallax] next:     parallax compose  (renders with audio mux)")

    duration_run = time.time() - started_at
    emitter.emit("run_complete", duration_s=round(duration_run, 2),
                 aligned_scenes=aligned_count)
    return 0


def cmd_compose(args) -> int:
    """
    Manifest-first render. Reads cwd/manifest.yaml and renders
    EXACTLY the scenes listed there — no globbing, no fallbacks.

    Each scene must have:
      still:    relative path to a still image
      duration: seconds for that scene
    Optional per-scene fields:
      motion:   ken-burns preset (default: zoom_drift_right)

    Optional top-level manifest fields:
      output_motion:     default motion if scenes don't specify one
      output_resolution: default '1080x1920'

    Reads:   cwd/manifest.yaml + the stills it references
    Writes:  cwd/output/<concept_id>_v<version>.mp4
    """
    cwd = Path.cwd()
    sys.path.insert(0, str(REPO_ROOT))
    os.environ["PARALLAX_LOG_DIR"] = str(cwd / "logs")
    _ensure_project_layout(cwd)

    run_id = uuid.uuid4().hex[:8]
    from core.events import emitter
    if getattr(args, "json", False):
        emitter.enable_json(run_id)
    from core.logging_setup import setup_run_logging
    setup_run_logging(run_id)
    log = logging.getLogger("parallax.compose")
    started_at = time.time()
    emitter.emit("run_started", brief="compose", mode="compose", project_dir=str(cwd))

    manifest_path = cwd / "manifest.yaml"
    if not manifest_path.exists():
        print("           run `parallax create` first or write a manifest.yaml",
              file=sys.stderr)
        return fail(f"manifest not found: {manifest_path}",
                    where="cmd_compose.read_manifest", exit_code=2)

    try:
        import yaml as _yaml
        with open(manifest_path) as f:
            manifest = _yaml.safe_load(f) or {}
    except Exception as e:
        return fail(f"failed to parse manifest: {e}",
                    where="cmd_compose.parse_manifest", log=log)

    scenes = manifest.get("scenes") or []
    if not scenes:
        return fail(
            "manifest has no scenes — add a `scenes:` list with `still` and `duration` per entry",
            where="cmd_compose.no_scenes", exit_code=3,
        )

    default_motion = manifest.get("output_motion") or "zoom_drift_right"
    resolution = manifest.get("output_resolution") or "1080x1920"
    concept_id = manifest.get("concept_id") or f"CMP-{int(time.time()) % 1000:03d}"

    valid_motions = {
        "zoom_in", "zoom_out", "zoom_drift_right", "zoom_drift_left",
        "zoom_drift_down", "zoom_drift_up", "pan_right", "pan_left",
        "pan_down", "pan_up",
    }

    # Validate every scene before rendering anything — fail fast.
    # A scene is one of:
    #   - still scene: requires `still` (path) and `duration` (and optional motion)
    #   - video scene: type='video', requires `source` (path), optional start_s/end_s
    resolved_scenes = []
    for i, scene in enumerate(scenes, 1):
        if not isinstance(scene, dict):
            return fail(f"scene {i}: must be a mapping",
                        where="cmd_compose.validate", exit_code=3)

        scene_type = scene.get("type") or ("video" if scene.get("source") else "still")

        if scene_type == "video":
            source_rel = scene.get("source") or scene.get("video")
            if not source_rel:
                return fail(
                    f"scene {i}: video scene requires `source` (path to mp4/mov)",
                    where="cmd_compose.validate", exit_code=3,
                )
            source_path = (cwd / source_rel).resolve()
            if not source_path.exists():
                return fail(
                    f"scene {i}: video source not found: {source_rel}",
                    where="cmd_compose.validate", exit_code=2,
                )
            start_s = scene.get("start_s")
            end_s = scene.get("end_s")
            duration = scene.get("duration")
            try:
                if start_s is not None: start_s = float(start_s)
                if end_s is not None: end_s = float(end_s)
                if duration is not None: duration = float(duration)
            except (TypeError, ValueError):
                return fail(
                    f"scene {i}: start_s/end_s/duration must be numbers",
                    where="cmd_compose.validate", exit_code=3,
                )
            # Compute effective duration: prefer explicit, else end_s-start_s, else full clip
            if duration is None and start_s is not None and end_s is not None:
                duration = end_s - start_s
            resolved_scenes.append({
                "index": i,
                "type": "video",
                "source": source_path,
                "source_rel": source_rel,
                "start_s": start_s,
                "end_s": end_s,
                "duration": duration,
            })
        else:
            # still scene
            still_rel = scene.get("still")
            if not still_rel:
                return fail(f"scene {i}: still scene requires `still` (path)",
                            where="cmd_compose.validate", exit_code=3)
            still_path = (cwd / still_rel).resolve()
            if not still_path.exists():
                return fail(f"scene {i}: still not found: {still_rel}",
                            where="cmd_compose.validate", exit_code=2)
            duration = scene.get("duration")
            if duration is None:
                return fail(f"scene {i}: still scene requires `duration`",
                            where="cmd_compose.validate", exit_code=3)
            try:
                duration = float(duration)
            except (TypeError, ValueError):
                return fail(
                    f"scene {i}: duration must be a number, got {duration!r}",
                    where="cmd_compose.validate", exit_code=3,
                )
            motion = scene.get("motion") or default_motion
            if motion not in valid_motions:
                return fail(
                    f"scene {i}: invalid motion {motion!r}. Valid: {sorted(valid_motions)}",
                    where="cmd_compose.validate", exit_code=3,
                )
            resolved_scenes.append({
                "index": i,
                "type": "still",
                "still": still_path,
                "still_rel": still_rel,
                "duration": duration,
                "motion": motion,
            })

    print(f"[parallax] composing {len(resolved_scenes)} scene(s) from manifest")
    print(f"[parallax] concept:  {concept_id}")
    print(f"[parallax] resolution: {resolution}")
    print()

    ken_burns_script = BUNDLED_SCRIPTS / "ken-burns.py"
    if not ken_burns_script.exists():
        return fail(f"ken-burns.py not found at {ken_burns_script}",
                    where="cmd_compose.script_missing", exit_code=2)

    output_dir = cwd / "output"
    output_dir.mkdir(parents=True, exist_ok=True)

    import subprocess as _sp, tempfile
    clip_paths = []
    # Parse resolution into width/height for video normalization
    try:
        res_w, res_h = (int(x) for x in resolution.split("x"))
    except Exception:
        res_w, res_h = 1080, 1920

    with tempfile.TemporaryDirectory(prefix="parallax-compose-") as tmpdir:
        for scene in resolved_scenes:
            clip_path = Path(tmpdir) / f"clip_{scene['index']:02d}.mp4"
            try:
                if scene["type"] == "still":
                    print(
                        f"[parallax] scene {scene['index']} (still): {scene['still'].name} "
                        f"({scene['motion']}, {scene['duration']}s)...",
                        end=" ", flush=True,
                    )
                    result = _sp.run(
                        [sys.executable, str(ken_burns_script),
                         "--input", str(scene["still"]),
                         "--output", str(clip_path),
                         "--duration", str(scene["duration"]),
                         "--motion", scene["motion"],
                         "--resolution", resolution],
                        capture_output=True, text=True, timeout=180,
                    )
                    if result.returncode != 0:
                        print(f"FAILED\n{result.stderr.strip()}", file=sys.stderr)
                        return fail(f"ken-burns failed for scene {scene['index']}",
                                    where="cmd_compose.ken_burns", log=log)
                else:
                    # video scene: trim + scale + pad to target resolution
                    if scene.get("start_s") is not None:
                        trim_label = f" ({scene['start_s']}–{scene['end_s']})"
                    else:
                        trim_label = ""
                    print(
                        f"[parallax] scene {scene['index']} (video): {scene['source'].name}"
                        f"{trim_label}...",
                        end=" ", flush=True,
                    )
                    cmd = ["ffmpeg", "-y", "-hide_banner", "-loglevel", "error"]
                    if scene.get("start_s") is not None:
                        cmd += ["-ss", str(scene["start_s"])]
                    cmd += ["-i", str(scene["source"])]
                    if scene.get("end_s") is not None and scene.get("start_s") is not None:
                        cmd += ["-t", str(scene["end_s"] - scene["start_s"])]
                    elif scene.get("duration") is not None:
                        cmd += ["-t", str(scene["duration"])]
                    # Scale to fit, pad to exact res, force 30fps + libx264 + aac for concat compat
                    vf = (
                        f"scale={res_w}:{res_h}:force_original_aspect_ratio=decrease,"
                        f"pad={res_w}:{res_h}:(ow-iw)/2:(oh-ih)/2,setsar=1,fps=30"
                    )
                    cmd += [
                        "-vf", vf,
                        "-c:v", "libx264", "-preset", "fast", "-crf", "20",
                        "-pix_fmt", "yuv420p",
                        "-an",  # strip audio — voiceover is muxed in later
                        str(clip_path),
                    ]
                    result = _sp.run(cmd, capture_output=True, text=True, timeout=300)
                    if result.returncode != 0:
                        print(f"FAILED\n{result.stderr.strip()[-500:]}", file=sys.stderr)
                        return fail(f"video scene {scene['index']} failed",
                                    where="cmd_compose.video_scene", log=log)
                clip_paths.append(str(clip_path))
                emitter.emit("still_generated", path=str(clip_path), scene=scene["index"])
                print("done")
            except Exception as e:
                return fail(str(e),
                            where=f"cmd_compose.scene_{scene['index']}", log=log)

        from core.project_layout import next_version, update_latest_symlink
        version = next_version(cwd, concept_id)
        silent_path = Path(tmpdir) / f"silent_{concept_id}_v{version}.mp4"
        output_path = output_dir / f"{concept_id}_v{version}.mp4"
        concat_list = Path(tmpdir) / "concat.txt"
        concat_list.write_text("\n".join(f"file '{p}'" for p in clip_paths))

        print(f"\n[parallax] assembling → {output_path.name}...", end=" ", flush=True)
        emitter.emit("assembly_started", clip_count=len(clip_paths), output_path=str(output_path))
        try:
            result = _sp.run(
                ["ffmpeg", "-y", "-f", "concat", "-safe", "0",
                 "-i", str(concat_list),
                 "-c", "copy", str(silent_path)],
                capture_output=True, text=True, timeout=300,
            )
            if result.returncode != 0:
                print(f"FAILED\n{result.stderr[-500:]}", file=sys.stderr)
                return fail(f"ffmpeg concat failed rc={result.returncode}",
                            where="cmd_compose.assembly", log=log)
            print("done")
        except Exception as e:
            return fail(str(e), where="cmd_compose.assembly", log=log)

        # ── Audio mux ────────────────────────────────────────────────────────
        # If manifest.voiceover.audio_file exists, mux it into the silent video.
        # Otherwise, copy the silent video to the output path.
        vo_info = manifest.get("voiceover") or {}
        vo_rel = vo_info.get("audio_file") if isinstance(vo_info, dict) else None
        vo_audio_path = (cwd / vo_rel).resolve() if vo_rel else None
        if vo_audio_path and vo_audio_path.exists():
            print(f"[parallax] muxing audio: {vo_rel}...", end=" ", flush=True)
            try:
                result = _sp.run(
                    ["ffmpeg", "-y",
                     "-i", str(silent_path),
                     "-i", str(vo_audio_path),
                     "-c:v", "copy", "-c:a", "aac", "-b:a", "192k",
                     "-shortest",
                     str(output_path)],
                    capture_output=True, text=True, timeout=300,
                )
                if result.returncode != 0:
                    print(f"FAILED\n{result.stderr[-500:]}", file=sys.stderr)
                    return fail(f"ffmpeg mux failed rc={result.returncode}",
                                where="cmd_compose.mux", log=log)
                print("done")
                emitter.emit("audio_muxed", audio_file=vo_rel, output_path=str(output_path))
            except Exception as e:
                return fail(str(e), where="cmd_compose.mux", log=log)
        else:
            try:
                _sp.run(["cp", str(silent_path), str(output_path)], check=True)
            except Exception as e:
                return fail(str(e), where="cmd_compose.copy", log=log)

        # ── Headline overlay ─────────────────────────────────────────────────
        # If manifest.headline is set, generate a PNG via generate-caption.py
        # and burn it in for the full video duration (or a window).
        headline_cfg = manifest.get("headline")
        if headline_cfg:
            # Default style is "title" (transparent overlay in the top safe
            # zone). "banner" is a FULL-SCREEN SOLID title card and covers all
            # video content — only use when the user explicitly asks for a
            # title card. Never default to banner.
            headline_position = None
            if isinstance(headline_cfg, str):
                headline_text = headline_cfg
                headline_style = "title"
                headline_start = 0.0
                headline_end = None
            elif isinstance(headline_cfg, dict):
                headline_text = headline_cfg.get("text", "")
                headline_style = headline_cfg.get("style", "title")
                headline_start = float(headline_cfg.get("start_s", 0.0))
                headline_end = headline_cfg.get("end_s")
                headline_position = headline_cfg.get("position")
                if headline_end is not None:
                    headline_end = float(headline_end)
            else:
                headline_text = ""
                headline_style = "title"
                headline_start = 0.0
                headline_end = None

            if headline_text:
                gen_caption_script = BUNDLED_SCRIPTS / "generate-caption.py"
                if not gen_caption_script.exists():
                    print(f"[parallax] WARNING: generate-caption.py not found, skipping headline",
                          file=sys.stderr)
                else:
                    headline_png = Path(tmpdir) / "headline.png"
                    print(f"[parallax] rendering headline: {headline_text!r}...", end=" ", flush=True)
                    try:
                        gen_cmd = [sys.executable, str(gen_caption_script),
                             "--text", headline_text,
                             "--style", headline_style,
                             "--resolution", resolution,
                             "--output", str(headline_png)]
                        if headline_position:
                            gen_cmd += ["--position", headline_position]
                        result = _sp.run(
                            gen_cmd,
                            capture_output=True, text=True, timeout=60,
                        )
                        if result.returncode != 0:
                            print(f"FAILED\n{result.stderr[-500:]}", file=sys.stderr)
                        else:
                            print("done")
                            # Burn the PNG over the video for the requested window
                            with_headline = output_dir / f"{concept_id}_v{version}_headlined.mp4"
                            enable_expr = f"between(t,{headline_start},{headline_end})" if headline_end is not None else f"gte(t,{headline_start})"
                            print(f"[parallax] burning headline overlay...", end=" ", flush=True)
                            ov_result = _sp.run(
                                ["ffmpeg", "-y", "-hide_banner", "-loglevel", "error",
                                 "-i", str(output_path),
                                 "-i", str(headline_png),
                                 "-filter_complex",
                                 f"[0:v][1:v]overlay=0:0:enable='{enable_expr}'[outv]",
                                 "-map", "[outv]", "-map", "0:a?",
                                 "-c:v", "libx264", "-preset", "fast", "-crf", "20",
                                 "-c:a", "copy",
                                 str(with_headline)],
                                capture_output=True, text=True, timeout=300,
                            )
                            if ov_result.returncode != 0:
                                print(f"FAILED\n{ov_result.stderr[-500:]}", file=sys.stderr)
                            else:
                                print("done")
                                with_headline.replace(output_path)
                                emitter.emit("headline_burned", text=headline_text)
                    except Exception as e:
                        print(f"ERROR: {e}", file=sys.stderr)

        # ── Caption burn ─────────────────────────────────────────────────────
        # If voiceover and vo_manifest both exist AND manifest.captions.enabled
        # is truthy (default off — opt in), burn word-level captions.
        captions_cfg = manifest.get("captions") or {}
        captions_enabled = bool(captions_cfg.get("enabled"))
        vo_manifest_rel = vo_info.get("vo_manifest") if isinstance(vo_info, dict) else None
        vo_manifest_path_full = (cwd / vo_manifest_rel).resolve() if vo_manifest_rel else None
        if captions_enabled and vo_manifest_path_full and vo_manifest_path_full.exists():
            burn_script = BUNDLED_SCRIPTS / "burn-captions.py"
            if burn_script.exists():
                # burn-captions.py uses the video-production manifest schema
                # which expects project as a dict with id + config.resolution.
                # Write a stub manifest in tmpdir that satisfies that schema
                # while pointing at our real vo_manifest.
                import yaml as _yaml
                stub_manifest = {
                    "project": {
                        "id": concept_id,
                        "name": str(manifest.get("project") or "parallax"),
                    },
                    "config": {
                        "resolution": resolution,
                        "fps": 30,
                    },
                    "voiceover": {
                        "vo_manifest": str(vo_manifest_path_full),
                    },
                }
                stub_path = Path(tmpdir) / "burn_captions_stub.yaml"
                stub_path.write_text(_yaml.dump(stub_manifest))

                captioned_path = output_dir / f"{concept_id}_v{version}_captioned.mp4"
                print(f"[parallax] burning captions...", end=" ", flush=True)
                try:
                    result = _sp.run(
                        [sys.executable, str(burn_script),
                         "--manifest", str(stub_path),
                         "--video", str(output_path),
                         "--vo-manifest", str(vo_manifest_path_full),
                         "--output", str(captioned_path),
                         "--block-bg"],
                        capture_output=True, text=True, timeout=600,
                    )
                    if result.returncode != 0:
                        print(f"FAILED\n{result.stderr[-500:]}", file=sys.stderr)
                        emitter.emit("error", message="burn-captions failed",
                                     where="cmd_compose.captions")
                    else:
                        print("done")
                        # Replace output with captioned version
                        captioned_path.replace(output_path)
                        emitter.emit("captions_burned", output_path=str(output_path))
                except Exception as e:
                    print(f"ERROR: {e}", file=sys.stderr)
                    emitter.emit("error", message=str(e), where="cmd_compose.captions")
            else:
                print(f"[parallax] WARNING: burn-captions.py not found, skipping captions",
                      file=sys.stderr)

        emitter.emit("assembly_complete", output_path=str(output_path))

    # Update manifest with output_video field (preserve existing content).
    try:
        content = manifest_path.read_text()
        if "output_video:" in content:
            import re
            content = re.sub(r'output_video:.*', f'output_video: "output/{output_path.name}"', content)
        else:
            content = content.rstrip() + f'\noutput_video: "output/{output_path.name}"\n'
        manifest_path.write_text(content)
    except Exception as e:
        print(f"[parallax] WARNING: could not update manifest: {e}", file=sys.stderr)

    try:
        update_latest_symlink(cwd, output_path)
    except Exception as e:
        print(f"[parallax] WARNING: could not update latest.mp4: {e}", file=sys.stderr)

    print()
    print(f"[parallax] final: ./output/{output_path.name}")

    duration_s = time.time() - started_at
    emitter.emit("run_complete", output_path=str(output_path), duration_s=round(duration_s, 2))
    return 0


def cmd_manifest_edit(args) -> int:
    """
    Apply a single edit to cwd/manifest.yaml.

    Operations:
      set-scenes <still1[:duration[:motion]]> ...   replace scenes list
      add-scene <still> [--duration N] [--motion M] append a scene
      remove-scene <number>                         remove scene by number
      reorder <number,number,...>                   reorder scenes
      set <key> <value>                             set top-level key
      show                                          print current manifest
    """
    cwd = Path.cwd()
    _ensure_project_layout(cwd)
    manifest_path = cwd / "manifest.yaml"

    import yaml as _yaml
    if manifest_path.exists():
        try:
            with open(manifest_path) as f:
                manifest = _yaml.safe_load(f) or {}
        except Exception as e:
            print(f"[parallax] ERROR: failed to parse manifest: {e}", file=sys.stderr)
            return 1
    else:
        # Lazy-init a blank manifest so set-scenes/add-scene/etc. work from scratch
        manifest = {
            "project": cwd.name,
            "concept_id": f"PRX-{int(time.time()) % 1000:03d}",
            "scenes": [],
        }

    op = args.op

    if op == "show":
        import yaml as _yaml
        print(_yaml.dump(manifest, sort_keys=False, default_flow_style=False))
        return 0

    scenes = manifest.get("scenes") or []

    if op == "set-scenes":
        if not args.values:
            print("[parallax] ERROR: set-scenes needs at least one still spec", file=sys.stderr)
            return 1
        new_scenes = []
        for i, spec in enumerate(args.values, 1):
            parts = spec.split(":")
            still = parts[0]
            duration = float(parts[1]) if len(parts) > 1 and parts[1] else 3.0
            motion = parts[2] if len(parts) > 2 and parts[2] else None
            still_path = (cwd / still).resolve()
            if not still_path.exists():
                print(f"[parallax] ERROR: still not found: {still}", file=sys.stderr)
                return 1
            scene = {"number": i, "duration": duration, "still": still}
            if motion:
                scene["motion"] = motion
            new_scenes.append(scene)
        manifest["scenes"] = new_scenes

    elif op == "add-scene":
        if not args.values:
            print("[parallax] ERROR: add-scene needs a still path", file=sys.stderr)
            return 1
        still = args.values[0]
        still_path = (cwd / still).resolve()
        if not still_path.exists():
            print(f"[parallax] ERROR: still not found: {still}", file=sys.stderr)
            return 1
        new_num = max((s.get("number", 0) for s in scenes), default=0) + 1
        scene = {"number": new_num, "duration": args.duration, "still": still}
        if args.motion:
            scene["motion"] = args.motion
        scenes.append(scene)
        manifest["scenes"] = scenes

    elif op == "remove-scene":
        if not args.values:
            print("[parallax] ERROR: remove-scene needs a scene number", file=sys.stderr)
            return 1
        try:
            target = int(args.values[0])
        except ValueError:
            print(f"[parallax] ERROR: scene number must be an integer", file=sys.stderr)
            return 1
        scenes = [s for s in scenes if s.get("number") != target]
        for i, s in enumerate(scenes, 1):
            s["number"] = i
        manifest["scenes"] = scenes

    elif op == "reorder":
        if not args.values:
            print("[parallax] ERROR: reorder needs comma-separated scene numbers", file=sys.stderr)
            return 1
        try:
            order = [int(x) for x in args.values[0].split(",")]
        except ValueError:
            print(f"[parallax] ERROR: reorder values must be integers", file=sys.stderr)
            return 1
        by_num = {s.get("number"): s for s in scenes}
        new_scenes = []
        for new_idx, old_num in enumerate(order, 1):
            if old_num not in by_num:
                print(f"[parallax] ERROR: scene {old_num} not in manifest", file=sys.stderr)
                return 1
            s = dict(by_num[old_num])
            s["number"] = new_idx
            new_scenes.append(s)
        manifest["scenes"] = new_scenes

    elif op == "set":
        if len(args.values) < 2:
            print("[parallax] ERROR: set needs <key> <value>", file=sys.stderr)
            return 1
        key, value = args.values[0], args.values[1]
        # Try to coerce to int/float, fall back to string
        try:
            value = int(value)
        except ValueError:
            try:
                value = float(value)
            except ValueError:
                pass
        manifest[key] = value

    elif op == "set-vo":
        # set-vo <scene_number> "<text>"
        if len(args.values) < 2:
            print("[parallax] ERROR: set-vo needs <scene_number> <text>", file=sys.stderr)
            return 1
        try:
            target = int(args.values[0])
        except ValueError:
            print("[parallax] ERROR: scene number must be an integer", file=sys.stderr)
            return 1
        text = " ".join(args.values[1:])
        found = False
        for s in scenes:
            if s.get("number") == target:
                s["vo_text"] = text
                found = True
                break
        if not found:
            print(f"[parallax] ERROR: scene {target} not in manifest", file=sys.stderr)
            return 1
        manifest["scenes"] = scenes

    elif op == "set-voice":
        # set-voice <name_or_id>
        if not args.values:
            print("[parallax] ERROR: set-voice needs a voice name or id", file=sys.stderr)
            return 1
        voice_input = args.values[0]
        manifest["voice"] = {
            "voice_name": voice_input,
            "voice_id": voice_input,
        }

    elif op == "enable-captions":
        manifest["captions"] = {"enabled": True}

    elif op == "disable-captions":
        manifest["captions"] = {"enabled": False}

    elif op == "set-headline":
        if not args.values:
            print("[parallax] ERROR: set-headline needs the headline text", file=sys.stderr)
            return 1
        # values: [text] | [text, style] | [text, style, position]
        # style defaults to "title" — a transparent top-safe-zone overlay.
        # The old "banner" default rendered a full-screen solid black card that
        # covered all video content; never what a headline-over-KenBurns wants.
        text = args.values[0]
        style = args.values[1] if len(args.values) > 1 else "title"
        if style not in ("title", "caption", "banner"):
            print(f"[parallax] ERROR: unknown headline style {style!r} (title|caption|banner)", file=sys.stderr)
            return 1
        headline_entry = {"text": text, "style": style}
        if len(args.values) > 2:
            headline_entry["position"] = args.values[2]
        manifest["headline"] = headline_entry

    elif op == "clear-headline":
        manifest.pop("headline", None)

    elif op == "validate":
        # V2: validate manifest against V2 schema rules. Exit 0 = valid, 1 = errors.
        errors = []
        scenes = manifest.get("scenes") or []
        if not manifest.get("project"):
            errors.append("project.name is required")
        if not scenes:
            errors.append("scenes list is empty")
        for i, scene in enumerate(scenes, 1):
            if not isinstance(scene, dict):
                errors.append(f"scene {i}: must be a mapping")
                continue
            num = scene.get("number") or scene.get("scene")
            if num != i:
                errors.append(f"scene {i}: number={num!r} (expected {i} — must be sequential from 1)")
            dur = scene.get("duration") or scene.get("duration_sec")
            if dur is None:
                errors.append(f"scene {i}: duration is required")
            else:
                try:
                    if float(dur) <= 0:
                        errors.append(f"scene {i}: duration must be > 0")
                except (TypeError, ValueError):
                    errors.append(f"scene {i}: duration must be a number, got {dur!r}")
            # Warn (not error) if still is set but file is missing
            still = scene.get("still")
            if still and not (cwd / still).resolve().exists():
                errors.append(f"scene {i}: still not found: {still}")
        res = manifest.get("output_resolution")
        if res:
            import re as _re
            if not _re.match(r"^\d+x\d+$", str(res)):
                errors.append(f"output_resolution must match WxH, got {res!r}")
        fps = manifest.get("output_fps")
        if fps and int(fps) not in (12, 24, 30, 60):
            errors.append(f"output_fps must be 12|24|30|60, got {fps!r}")

        if errors:
            print(f"[parallax] manifest validation FAILED — {len(errors)} error(s):")
            for err in errors:
                print(f"  ✗ {err}")
            return 1
        else:
            print(f"[parallax] manifest valid ({len(scenes)} scene(s))")
            return 0

    elif op == "add-video-scene":
        # add-video-scene <source_path> [--start-s X] [--end-s Y]
        if not args.values:
            print("[parallax] ERROR: add-video-scene needs a source path", file=sys.stderr)
            return 1
        src = args.values[0]
        src_path = (cwd / src).resolve()
        if not src_path.exists():
            print(f"[parallax] ERROR: video source not found: {src}", file=sys.stderr)
            return 1
        new_num = max((s.get("number", 0) for s in scenes), default=0) + 1
        scene = {"number": new_num, "type": "video", "source": src}
        # Optional start/end via flags
        if hasattr(args, "start_s") and args.start_s is not None:
            scene["start_s"] = args.start_s
        if hasattr(args, "end_s") and args.end_s is not None:
            scene["end_s"] = args.end_s
        if hasattr(args, "duration") and args.duration is not None and args.duration != 3.0:
            scene["duration"] = args.duration
        scenes.append(scene)
        manifest["scenes"] = scenes

    else:
        print(f"[parallax] ERROR: unknown op {op!r}", file=sys.stderr)
        return 1

    try:
        import yaml as _yaml
        with open(manifest_path, "w") as f:
            _yaml.dump(manifest, f, sort_keys=False, default_flow_style=False)
    except Exception as e:
        print(f"[parallax] ERROR: failed to write manifest: {e}", file=sys.stderr)
        return 1

    print(f"[parallax] manifest updated: {op}")
    return 0


def cmd_update(args) -> int:
    """
    Pull the latest Parallax from GitHub and reinstall.
    Does the install steps directly in Python — no dependency on `just`.
    """
    import shutil
    import subprocess as sp

    print("Parallax update\n" + "=" * 40)

    # Verify we're in a git repo
    r = sp.run(
        ["git", "-C", str(REPO_ROOT), "rev-parse", "--is-inside-work-tree"],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        print("error: repo not found — was Parallax installed via git clone?")
        print(f"  expected repo at: {REPO_ROOT}")
        return 1

    # --- Pull ------------------------------------------------------------------
    print("pulling from origin/main...")
    try:
        pull = sp.run(
            ["git", "-C", str(REPO_ROOT), "pull", "--ff-only", "origin", "main"],
            capture_output=True, text=True,
        )
        sys.stdout.write(pull.stdout)
        if pull.returncode != 0:
            print(f"git pull failed:\n{pull.stderr}", file=sys.stderr)
            return 1
    except Exception as e:
        print(f"git pull failed: {e}", file=sys.stderr)
        return 1

    # --- CLI symlink -----------------------------------------------------------
    local_bin = Path.home() / ".local" / "bin"
    local_bin.mkdir(parents=True, exist_ok=True)
    symlink = local_bin / "parallax"
    target = REPO_ROOT / "bin" / "parallax"
    try:
        if symlink.is_symlink() or symlink.exists():
            symlink.unlink()
        symlink.symlink_to(target)
        print(f"linked {symlink} -> {target}")
    except Exception as e:
        print(f"warning: could not update symlink: {e}", file=sys.stderr)

    # --- Web venv --------------------------------------------------------------
    # Find Python 3.11+ — prefer the same interpreter running this script if
    # it's new enough, so we use the venv python that's known to work.
    python = None
    if sys.version_info >= (3, 11):
        python = sys.executable
    else:
        for candidate in ("python3.12", "python3.11"):
            found = shutil.which(candidate)
            if found:
                python = found
                break

    if not python:
        print("error: Python 3.11+ not found — install with: brew install python@3.11",
              file=sys.stderr)
        return 1

    venv_dir = REPO_ROOT / "web" / ".venv"
    req_file = REPO_ROOT / "web" / "requirements.txt"

    print(f"updating web venv at {venv_dir}...")
    try:
        r = sp.run([python, "-m", "venv", str(venv_dir)], capture_output=True, text=True)
        if r.returncode != 0:
            print(f"venv creation failed:\n{r.stderr}", file=sys.stderr)
            return 1
    except Exception as e:
        print(f"venv creation failed: {e}", file=sys.stderr)
        return 1

    # Use the venv's python to run pip — avoids the missing-pip-binary issue.
    venv_python = venv_dir / "bin" / "python3"
    try:
        r = sp.run(
            [str(venv_python), "-m", "pip", "install", "--quiet", "--upgrade", "pip"],
            capture_output=True, text=True,
        )
        if r.returncode != 0:
            print(f"pip upgrade failed:\n{r.stderr}", file=sys.stderr)
            return 1

        r = sp.run(
            [str(venv_python), "-m", "pip", "install", "-r", str(req_file)],
            text=True,
        )
        if r.returncode != 0:
            return 1
    except Exception as e:
        print(f"pip install failed: {e}", file=sys.stderr)
        return 1

    # --- Done ------------------------------------------------------------------
    _clear_update_cache()
    print("\nParallax is up to date.")
    return 0


# ---------------------------------------------------------------------------
# Daily update check
# ---------------------------------------------------------------------------

_UPDATE_CACHE = Path.home() / ".parallax" / ".update_check"
_UPDATE_INTERVAL = 86400  # 24 hours
_REMOTE_URL = "https://github.com/ianjamesburke/parallax-cli"


def _clear_update_cache() -> None:
    try:
        _UPDATE_CACHE.unlink(missing_ok=True)
    except Exception:
        pass


def _check_for_update_once() -> None:
    """
    Run at most once per 24 hours. Compares local HEAD with origin/main HEAD
    via git ls-remote. Prints a single-line notice if behind, then exits.
    Completely silent on any failure — never blocks the main command.
    """
    import subprocess as sp

    try:
        import json as _j

        # Read cache
        now = time.time()
        if _UPDATE_CACHE.exists():
            try:
                cached = _j.loads(_UPDATE_CACHE.read_text())
                if now - cached.get("ts", 0) < _UPDATE_INTERVAL:
                    if cached.get("behind"):
                        print(
                            f'[parallax] update available — run "parallax update" to get the latest',
                            file=sys.stderr,
                        )
                    return
            except Exception:
                pass

        # Fetch remote HEAD (fast — no clone, just a single ref lookup)
        r = sp.run(
            ["git", "-C", str(REPO_ROOT), "ls-remote", "origin", "HEAD"],
            capture_output=True, text=True, timeout=5,
        )
        if r.returncode != 0:
            return

        remote_sha = r.stdout.split()[0] if r.stdout.strip() else ""
        if not remote_sha:
            return

        local_r = sp.run(
            ["git", "-C", str(REPO_ROOT), "rev-parse", "HEAD"],
            capture_output=True, text=True, timeout=3,
        )
        local_sha = local_r.stdout.strip() if local_r.returncode == 0 else ""

        behind = bool(remote_sha and local_sha and remote_sha != local_sha)

        # Write cache
        _UPDATE_CACHE.parent.mkdir(parents=True, exist_ok=True)
        _UPDATE_CACHE.write_text(_j.dumps({"ts": now, "behind": behind, "remote_sha": remote_sha}))

        if behind:
            print(
                f'[parallax] update available — run "parallax update" to get the latest',
                file=sys.stderr,
            )
    except Exception:
        pass  # never surface update-check errors


def cmd_setup(args) -> int:
    """
    Check dependencies and guide first-time setup.
    Run this once after installing Parallax.
    """
    import shutil
    sys.path.insert(0, str(REPO_ROOT))
    sys.path.insert(0, str(BUNDLED_SCRIPTS))

    ok = True

    print("Parallax setup check\n" + "=" * 40)

    # --- Python version ---
    if sys.version_info < (3, 11):
        print(f"  ✗ Python         {sys.version_info.major}.{sys.version_info.minor}  (3.11+ required)")
        print(f"                  install: brew install python@3.11")
        return 1
    print(f"  ✓ Python         {sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}")

    # --- ffmpeg ---
    ffmpeg = shutil.which("ffmpeg")
    if ffmpeg:
        print(f"  ✓ ffmpeg        {ffmpeg}")
    else:
        print(f"  ✗ ffmpeg        NOT FOUND")
        print(f"                  install: brew install ffmpeg")
        ok = False

    # --- Python / Pillow ---
    try:
        import PIL
        print(f"  ✓ Pillow        {PIL.__version__}")
    except ImportError:
        print(f"  ✗ Pillow        NOT FOUND")
        print(f"                  install: pip install Pillow")
        ok = False

    # --- google-genai ---
    try:
        import google.genai
        print(f"  ✓ google-genai  OK")
    except ImportError:
        print(f"  ✗ google-genai  NOT FOUND")
        print(f"                  install: pip install google-genai")
        ok = False

    # --- Gemini API key ---
    try:
        from api_config import get_gemini_key
        key = get_gemini_key()
    except Exception:
        key = os.environ.get("AI_VIDEO_GEMINI_KEY") or os.environ.get("GEMINI_API_KEY")

    if key:
        print(f"  ✓ Gemini key    set ({key[:8]}...)")
    else:
        print(f"  ✗ Gemini key    NOT SET  ← required for image generation")
        print(f"")
        print(f"  To fix: add this to your ~/.zshrc (or ~/.zsh_secrets):")
        print(f'    export AI_VIDEO_GEMINI_KEY="your-key-here"')
        print(f"")
        print(f"  Get a key at: https://aistudio.google.com/app/apikey")
        ok = False

    # --- Anthropic key (for parallax run / HoP) ---
    anthropic_key = os.environ.get("ANTHROPIC_API_KEY")
    if anthropic_key:
        print(f"  ✓ Anthropic key set ({anthropic_key[:8]}...)")
    else:
        print(f"  ◌ Anthropic key NOT SET  (optional — needed for parallax run)")
        print(f'    export ANTHROPIC_API_KEY="your-key-here"')

    # --- bundled scripts ---
    kb = BUNDLED_SCRIPTS / "ken-burns.py"
    if kb.exists():
        script_count = len(list(BUNDLED_SCRIPTS.glob("*.py")))
        print(f"  ✓ bundled scripts  {script_count} scripts at {BUNDLED_SCRIPTS}")
    else:
        print(f"  ✗ bundled scripts  NOT FOUND at {BUNDLED_SCRIPTS}")
        print(f"                  (the parallax install looks corrupted — reinstall)")
        ok = False

    # --- parallax on PATH ---
    parallax_bin = shutil.which("parallax")
    if parallax_bin:
        print(f"  ✓ parallax CLI  {parallax_bin}")
    else:
        this = Path(__file__).resolve()
        print(f"  ✗ parallax CLI  not on PATH")
        print(f"                  fix: ln -sf {this} /usr/local/bin/parallax")
        ok = False

    print()
    if ok:
        print("All required dependencies found. You're good to go.")
        print()
        print("Quick start:")
        print('  mkdir my-project && cd my-project')
        print('  parallax create "your creative brief" --count 3')
        print('  parallax animate')
    else:
        print("Fix the items marked ✗ above, then re-run: parallax setup")

    return 0 if ok else 1


def cmd_project_new(args: argparse.Namespace) -> int:
    proj = PROJECTS_ROOT / args.name
    if proj.exists():
        print(f"[parallax] ERROR: {proj} already exists", file=sys.stderr)
        return 1
    # Scaffold the canonical Parallax project layout.
    for sub in ("input", "output", "drafts", "stills", "audio", "logs"):
        (proj / sub).mkdir(parents=True, exist_ok=True)
    print(str(proj.resolve()))
    return 0


def cmd_projects(args: argparse.Namespace) -> int:
    if not PROJECTS_ROOT.exists():
        print(f"[parallax] no projects directory yet at {PROJECTS_ROOT}")
        print("           run `parallax project new <name>` to create one")
        return 0
    subs = sorted(p.name for p in PROJECTS_ROOT.iterdir() if p.is_dir())
    if not subs:
        print(f"[parallax] {PROJECTS_ROOT} is empty")
        return 0
    for name in subs:
        print(name)
    return 0


